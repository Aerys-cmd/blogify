@page "/archive"
@model Blogify.Web.Areas.Blog.Pages.ArchivesModel
@{
    ViewData["Title"] = Localizer["Blog.Archives"].Value;
}
<header class="blog-list-header">
    <h1>@Localizer["Blog.Archives"]</h1>
</header>
@if (Model.Months.Count == 0)
{
    <div class="empty-state">@Localizer["Blog.NoPosts"]</div>
}
else
{
    <nav class="topic-links" aria-label="@Localizer["Blog.Archives"].Value">
        @foreach (ArchiveMonthViewModel month in Model.Months)
        {
            <a asp-area="Blog" asp-page="/Archive" asp-route-year="@month.Year" asp-route-month="@month.Month">
                @month.MonthStart.ToString("MMMM yyyy") (@month.Count)
            </a>
        }
    </nav>
}

@section Sidebar {
    @await Html.PartialAsync("_Sidebar", Model.Sidebar)
}
