@page "/tags"
@model Blogify.Web.Areas.Blog.Pages.TagsModel
@{
    ViewData["Title"] = Localizer["Blog.Tags"].Value;
}
<header class="pb-8">
    <h1 class="font-serif text-4xl leading-tight tracking-[-0.025em] md:text-6xl">@Localizer["Blog.Tags"]</h1>
</header>
@if (Model.Tags.Count == 0)
{
    <div class="border-y border-current/15 py-16 text-current/70">@Localizer["Blog.NoTags"]</div>
}
else
{
    <nav class="flex flex-wrap gap-2" aria-label="@Localizer["Blog.Tags"].Value">
        @foreach (TagLinkViewModel tag in Model.Tags)
        {
            <a asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug" class="rounded-full border border-current/20 px-3 py-1.5 text-sm font-bold no-underline transition-colors hover:bg-current/10 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4">@tag.Name</a>
        }
    </nav>
}

@section Sidebar {
    @await Html.PartialAsync("_Sidebar", Model.Sidebar)
}
