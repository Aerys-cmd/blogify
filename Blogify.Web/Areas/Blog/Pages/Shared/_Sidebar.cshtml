@inject Blogify.Web.Services.TenantContext TenantContext
@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">About this blog</h5>
        <p class="card-text text-muted mb-0">@TenantContext.CurrentTenant?.Title</p>
    </div>
</div>

<div class="card">
    <div class="card-header fw-semibold">Categories</div>
    @if (Model.Categories.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted mb-0">No categories yet.</p>
        </div>
    }
    else
    {
        <div class="list-group list-group-flush">
            @foreach (Blogify.Web.Areas.Blog.Pages.CategoryLinkViewModel category in Model.Categories)
            {
                <a asp-area="Blog"
                   asp-page="/Category"
                   asp-route-slug="@category.Slug"
                   class="list-group-item list-group-item-action">
                    @category.Name
                </a>
            }
        </div>
    }
</div>
