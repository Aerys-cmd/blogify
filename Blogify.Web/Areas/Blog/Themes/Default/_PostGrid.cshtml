@model IReadOnlyList<Blogify.Web.Areas.Blog.Pages.PostCardViewModel>
<div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
    @foreach (PostCardViewModel post in Model)
    {
        <article>
            @if (post.CoverImageUrl is not null)
            {
                <a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="mb-4 block aspect-[4/3] overflow-hidden bg-ink focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-brand">
                    <img src="@post.CoverImageUrl" alt="" class="h-full w-full object-cover transition duration-200 ease-out hover:scale-[1.02]" loading="lazy" decoding="async" />
                </a>
            }
            <p class="text-sm text-muted">@post.PublishedAt.ToString("D")</p>
            <h2 class="mt-2 font-serif text-2xl leading-tight">
                <a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="no-underline transition-colors hover:text-brand focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-brand">@post.Title</a>
            </h2>
            @if (post.Categories.Count > 0 || post.Tags.Count > 0)
            {
                <div class="mt-3 flex flex-wrap gap-2">
                    @foreach (CategoryLinkViewModel cat in post.Categories)
                    {
                        <a asp-area="Blog" asp-page="/Category" asp-route-slug="@cat.Slug" class="rounded-full bg-subtle px-3 py-1.5 text-xs font-bold no-underline transition-colors hover:bg-line focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-brand">@cat.Name</a>
                    }
                    @foreach (TagLinkViewModel tag in post.Tags)
                    {
                        <a asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug" class="rounded-full bg-subtle px-3 py-1.5 text-xs font-bold no-underline transition-colors hover:bg-line focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-brand">@tag.Name</a>
                    }
                </div>
            }
            @if (post.Excerpt is not null)
            {
                <p class="mt-3 leading-7 text-muted">@post.Excerpt</p>
            }
        </article>
    }
</div>
