@inject Blogify.Web.Services.TenantContext TenantContext
@inject Blogify.Web.Services.BlogBrandingService BrandingService
<!DOCTYPE html>
<html lang="@TenantContext.RequiredTenant.PublicLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    @await Html.PartialAsync("~/Areas/Blog/Themes/Shared/_BlogMeta.cshtml")
    <link rel="stylesheet" href="~/css/themes/default.css" asp-append-version="true" />
</head>
<body class="editorial-theme">
    @{
        Blogify.Web.Services.BlogBrandingAssets branding = await BrandingService.GetAssetsAsync();
    }
    <header class="site-header">
        <div class="site-shell header-row">
            <a asp-area="Blog" asp-page="/Index" class="site-title site-brand">
                @if (!string.IsNullOrWhiteSpace(branding.LogoUrl))
                {
                    <img src="@branding.LogoUrl" alt="" class="site-logo" />
                }
                <span>@TenantContext.RequiredTenant.Title</span>
            </a>
            <a asp-area="Blog" asp-page="/Index" class="home-link">@Localizer["Blog.AllWriting"]</a>
        </div>
    </header>
    <main class="site-shell page-shell">@RenderBody()@await RenderSectionAsync("Sidebar", required: false)</main>
    <footer class="site-footer"><div class="site-shell">&copy; @TenantContext.RequiredTenant.CreatedAt.Year <strong>@TenantContext.RequiredTenant.Title</strong></div></footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
