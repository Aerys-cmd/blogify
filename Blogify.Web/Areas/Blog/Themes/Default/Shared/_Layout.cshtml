@inject Blogify.Web.Services.TenantContext TenantContext
<!DOCTYPE html>
<html lang="@TenantContext.RequiredTenant.PublicLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    @{
        string blogTitle = TenantContext.RequiredTenant.Title;
        string pageTitle = ViewData["Title"] as string ?? blogTitle;
        string? metaTitle = ViewData["MetaTitle"] as string ?? pageTitle;
        string? metaDescription = ViewData["MetaDescription"] as string ?? TenantContext.RequiredTenant.MetaDescription;
        string? ogImage = ViewData["OgImage"] as string;
        string? ogType = ViewData["OgType"] as string ?? "website";
        string? canonicalUrl = ViewData["CanonicalUrl"] as string;
    }
    <title>@pageTitle — @blogTitle</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="alternate icon" href="~/favicon.ico" />
    @if (!string.IsNullOrEmpty(metaDescription)) { <meta name="description" content="@metaDescription" /> }
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:site_name" content="@blogTitle" />
    <meta property="og:type" content="@ogType" />
    @if (!string.IsNullOrEmpty(metaDescription)) { <meta property="og:description" content="@metaDescription" /> }
    @if (!string.IsNullOrEmpty(ogImage)) { <meta property="og:image" content="@ogImage" /> }
    @if (!string.IsNullOrEmpty(canonicalUrl)) { <link rel="canonical" href="@canonicalUrl" /><meta property="og:url" content="@canonicalUrl" /> }
    <link rel="stylesheet" href="~/css/themes/default.css" asp-append-version="true" />
</head>
<body class="editorial-theme">
    <header class="site-header">
        <div class="site-shell header-row">
            <a asp-area="Blog" asp-page="/Index" class="site-title">@TenantContext.RequiredTenant.Title</a>
            <a asp-area="Blog" asp-page="/Index" class="home-link">@Localizer["Blog.AllWriting"]</a>
        </div>
    </header>
    <main class="site-shell page-shell">@RenderBody()@await RenderSectionAsync("Sidebar", required: false)</main>
    <footer class="site-footer"><div class="site-shell">&copy; @TenantContext.RequiredTenant.CreatedAt.Year <strong>@TenantContext.RequiredTenant.Title</strong></div></footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
