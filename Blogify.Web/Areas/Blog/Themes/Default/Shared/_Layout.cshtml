@inject Blogify.Web.Services.TenantContext TenantContext
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        string blogTitle = TenantContext.CurrentTenant?.Title ?? string.Empty;
        string pageTitle = ViewData["Title"] as string ?? blogTitle;
        string? metaTitle = ViewData["MetaTitle"] as string ?? pageTitle;
        string? metaDescription = ViewData["MetaDescription"] as string ?? TenantContext.CurrentTenant?.MetaDescription;
        string? ogImage = ViewData["OgImage"] as string;
        string? ogType = ViewData["OgType"] as string ?? "website";
        string? canonicalUrl = ViewData["CanonicalUrl"] as string;
    }
    <title>@pageTitle — @blogTitle</title>
    @if (!string.IsNullOrEmpty(metaDescription))
    {
        <meta name="description" content="@metaDescription" />
    }
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:site_name" content="@blogTitle" />
    <meta property="og:type" content="@ogType" />
    @if (!string.IsNullOrEmpty(metaDescription))
    {
        <meta property="og:description" content="@metaDescription" />
    }
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    @if (!string.IsNullOrEmpty(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
        <meta property="og:url" content="@canonicalUrl" />
    }
    <meta name="twitter:card" content="@(string.IsNullOrEmpty(ogImage) ? "summary" : "summary_large_image")" />
    <meta name="twitter:title" content="@metaTitle" />
    @if (!string.IsNullOrEmpty(metaDescription))
    {
        <meta name="twitter:description" content="@metaDescription" />
    }
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta name="twitter:image" content="@ogImage" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="Blog" asp-page="/Index">
                    @TenantContext.CurrentTenant?.Title
                </a>
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#blogNav"
                        aria-controls="blogNav"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="blogNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Blog" asp-page="/Index">Home</a>
                        </li>
                    </ul>
                    <partial name="_LanguageSwitcher" />
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-5">
        <div class="row">
            <div class="col-lg-8">
                @RenderBody()
            </div>
            <div class="col-lg-4">
                @RenderSection("Sidebar", required: false)
            </div>
        </div>
    </main>

    <footer class="py-4 mt-auto bg-dark text-white">
        <div class="container text-center">
            <p class="mb-0">
                &copy; @TenantContext.CurrentTenant?.CreatedAt.Year — @TenantContext.CurrentTenant?.Title
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
