@model Blogify.Web.Areas.Blog.Pages.IndexModel
@if (Model.Posts.Count == 0)
{
    <div class="empty-state"><p>@Localizer["Blog.NoPosts"]</p></div>
}
else
{
    PostCardViewModel lead = Model.Posts[0];
    <section class="lead-story">
        <a asp-area="Blog" asp-page="/Post" asp-route-slug="@lead.Slug" class="lead-image">
            @if (lead.CoverImageUrl is not null) { <img src="@lead.CoverImageUrl" alt="" /> }
            else { <span aria-hidden="true">@Model.BlogTitle.Substring(0, 1).ToUpperInvariant()</span> }
        </a>
        <div class="lead-copy">
            <p class="section-label">@Localizer["Blog.LatestWriting"]</p>
            <h1><a asp-area="Blog" asp-page="/Post" asp-route-slug="@lead.Slug">@lead.Title</a></h1>
            <p class="date-line">@Localizer["Blog.Published", lead.PublishedAt.ToString("D")]</p>
            @if (lead.Excerpt is not null) { <p class="lead-excerpt">@lead.Excerpt</p> }
            <a asp-area="Blog" asp-page="/Post" asp-route-slug="@lead.Slug" class="read-link">@Localizer["Blog.ReadStory"] <span aria-hidden="true">→</span></a>
        </div>
    </section>
    @if (Model.Posts.Count > 1)
    {
        <section class="story-section"><h2>@Localizer["Blog.AllWriting"]</h2><div class="story-grid">
        @foreach (PostCardViewModel post in Model.Posts.Skip(1))
        {
            <article class="story-card">
                <a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="story-image">
                    @if (post.CoverImageUrl is not null) { <img src="@post.CoverImageUrl" alt="" loading="lazy" /> }
                    else { <span aria-hidden="true">@post.Title.Substring(0, 1).ToUpperInvariant()</span> }
                </a>
                <p class="date-line">@post.PublishedAt.ToString("D")</p>
                <h3><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h3>
                @if (post.Excerpt is not null) { <p>@post.Excerpt</p> }
            </article>
        }
        </div></section>
    }
}
