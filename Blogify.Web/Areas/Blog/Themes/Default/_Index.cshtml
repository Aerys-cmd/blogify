@model Blogify.Web.Areas.Blog.Pages.IndexModel

<h1 class="mb-4 fw-bold">@Model.BlogTitle</h1>

@if (Model.Posts.Count == 0)
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No posts published yet.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (PostCardViewModel post in Model.Posts)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (post.CoverImageUrl is not null)
                    {
                        <img src="@post.CoverImageUrl" class="card-img-top" alt="@post.Title" style="object-fit:cover;height:180px;" />
                    }
                    else
                    {
                        <div class="bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height:180px;" aria-hidden="true">
                            <span class="text-muted fs-1">&#128444;</span>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">
                            <a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="text-decoration-none stretched-link">
                                @post.Title
                            </a>
                        </h2>
                        <p class="text-muted small mb-2">@post.PublishedAt.ToString("MMMM d, yyyy")</p>
                        @if (post.Excerpt is not null)
                        {
                            <p class="card-text text-muted">@post.Excerpt</p>
                        }
                        @if (post.Categories.Count > 0)
                        {
                            <div class="mt-auto pt-2">
                                @foreach (CategoryLinkViewModel cat in post.Categories)
                                {
                                    <a asp-area="Blog"
                                       asp-page="/Category"
                                       asp-route-slug="@cat.Slug"
                                       class="badge bg-secondary text-decoration-none me-1">
                                        @cat.Name
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
