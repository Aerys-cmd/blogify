@model Blogify.Web.Areas.Blog.Pages.PostModel
<section class="comments" aria-labelledby="comments-heading">
<h2 id="comments-heading">@Localizer["Blog.Comments", Model.Comments.Count]</h2>
@if(Model.Comments.Count==0){<p class="empty-copy">@Localizer["Blog.NoComments"]</p>}
@foreach(CommentViewModel comment in Model.Comments){<article class="comment"><header><strong>@comment.AuthorName</strong><time>@comment.CreatedAt.ToString("g")</time></header><p>@comment.Content</p>@if(Model.IsAuthenticated){<details><summary>@Localizer["Blog.Reply"]</summary><form method="post"><input type="hidden" name="Input.ParentCommentId" value="@comment.Id"/><label for="reply-@comment.Id">@Localizer["Blog.ReplyTo", comment.AuthorName]</label><textarea id="reply-@comment.Id" name="Input.Content" maxlength="2000" required placeholder="@Localizer["Blog.ReplyPlaceholder"].Value"></textarea><button type="submit">@Localizer["Blog.PostReply"]</button></form></details>}@foreach(CommentViewModel reply in comment.Replies){<div class="reply"><header><strong>@reply.AuthorName</strong><time>@reply.CreatedAt.ToString("g")</time></header><p>@reply.Content</p></div>}</article>}
<div class="comment-form">@if(Model.IsAuthenticated){<h3>@Localizer["Blog.LeaveComment"]</h3><form method="post"><div asp-validation-summary="ModelOnly" class="validation"></div><label asp-for="Input.Content">@Localizer["Blog.YourComment"]</label><textarea asp-for="Input.Content" rows="5" maxlength="2000" placeholder="@Localizer["Blog.CommentPlaceholder"].Value"></textarea><span asp-validation-for="Input.Content" class="validation"></span><button type="submit">@Localizer["Blog.PostComment"]</button></form>}else{<p><a href="@Model.LoginUrl">@Localizer["Blog.SignIn"]</a> @Localizer["Blog.SignInSuffix"]</p>}</div>
</section>
