@model Blogify.Web.Areas.Blog.Pages.CategoryModel
<header class="category-header"><p class="section-label">@Localizer["Blog.Categories"]</p><h1>@Localizer["Blog.CategoryHeading", Model.CategoryName]</h1></header>
@if (Model.Posts.Count == 0) { <div class="empty-state"><p>@Localizer["Blog.NoCategoryPosts"]</p></div> }
else { <div class="story-grid">
@foreach (PostCardViewModel post in Model.Posts) {
<article class="story-card"><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="story-image">@if(post.CoverImageUrl is not null){<img src="@post.CoverImageUrl" alt="" loading="lazy" />}else{<span aria-hidden="true">@post.Title.Substring(0,1).ToUpperInvariant()</span>}</a><p class="date-line">@post.PublishedAt.ToString("D")</p><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</article>
}</div> }
