@inject Blogify.Web.Services.TenantContext TenantContext
@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel

<div class="mt-10 pt-8 border-t border-stone-200">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-500 mb-3">Categories</h2>
    @if (Model.Categories.Count == 0)
    {
        <p class="text-sm text-stone-400">No categories yet.</p>
    }
    else
    {
        <ul class="space-y-1">
            @foreach (CategoryLinkViewModel category in Model.Categories)
            {
                <li>
                    <a asp-area="Blog"
                       asp-page="/Category"
                       asp-route-slug="@category.Slug"
                       class="text-sm text-stone-600 hover:text-stone-900 border-l-2 border-transparent hover:border-stone-400 pl-2 transition-colors">
                        @category.Name
                    </a>
                </li>
            }
        </ul>
    }
</div>
