@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel
<aside class="mt-16 border-t border-[#181817] pt-6">
    <h2 class="text-xs font-extrabold">@Localizer["Blog.Discover"]</h2>
    <nav class="mt-4 flex flex-wrap gap-x-4 gap-y-2" aria-label="@Localizer["Blog.Discover"].Value">
        <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Search">@Localizer["Blog.Search"]</a>
        <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Archives">@Localizer["Blog.Archives"]</a>
        <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Categories">@Localizer["Blog.Categories"]</a>
        <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Tags">@Localizer["Blog.Tags"]</a>
    </nav>
    <h2 class="mt-7 text-xs font-extrabold">@Localizer["Blog.Categories"]</h2>
    @if (Model.Categories.Count == 0)
    {
        <p class="mt-3 text-sm text-[#686863]">@Localizer["Blog.NoCategories"]</p>
    }
    else
    {
        <nav class="mt-4 flex flex-wrap gap-x-4 gap-y-2" aria-label="@Localizer["Blog.Categories"]">
            @foreach (CategoryLinkViewModel category in Model.Categories)
            {
                <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Category" asp-route-slug="@category.Slug">@category.Name</a>
            }
        </nav>
    }
    <h2 class="mt-7 text-xs font-extrabold">@Localizer["Blog.Tags"]</h2>
    @if (Model.Tags.Count == 0)
    {
        <p class="mt-3 text-sm text-[#686863]">@Localizer["Blog.NoTags"]</p>
    }
    else
    {
        <nav class="mt-4 flex flex-wrap gap-x-4 gap-y-2" aria-label="@Localizer["Blog.Tags"]">
            @foreach (TagLinkViewModel tag in Model.Tags)
            {
                <a class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]" asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug">@tag.Name</a>
            }
        </nav>
    }
</aside>
