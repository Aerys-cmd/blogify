@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel
<aside class="journal-topics"><h2>@Localizer["Blog.Categories"]</h2>@if(Model.Categories.Count==0){<p>@Localizer["Blog.NoCategories"]</p>}else{<nav aria-label="@Localizer["Blog.Categories"]">@foreach(CategoryLinkViewModel category in Model.Categories){<a asp-area="Blog" asp-page="/Category" asp-route-slug="@category.Slug">@category.Name</a>}</nav>}</aside>
