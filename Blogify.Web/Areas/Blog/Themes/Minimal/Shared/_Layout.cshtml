@inject Blogify.Web.Services.TenantContext TenantContext
<!DOCTYPE html>
<html lang="@TenantContext.RequiredTenant.PublicLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    @{
        string blogTitle = TenantContext.RequiredTenant.Title;
        string pageTitle = ViewData["Title"] as string ?? blogTitle;
        string? metaTitle = ViewData["MetaTitle"] as string ?? pageTitle;
        string? metaDescription = ViewData["MetaDescription"] as string ?? TenantContext.RequiredTenant.MetaDescription;
        string? ogImage = ViewData["OgImage"] as string;
        string? canonicalUrl = ViewData["CanonicalUrl"] as string;
    }
    <title>@pageTitle — @blogTitle</title>
    @if (!string.IsNullOrEmpty(metaDescription)) { <meta name="description" content="@metaDescription" /> }
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:site_name" content="@blogTitle" />
    @if (!string.IsNullOrEmpty(metaDescription)) { <meta property="og:description" content="@metaDescription" /> }
    @if (!string.IsNullOrEmpty(ogImage)) { <meta property="og:image" content="@ogImage" /> }
    @if (!string.IsNullOrEmpty(canonicalUrl)) { <link rel="canonical" href="@canonicalUrl" /> }
    <link rel="stylesheet" href="~/css/themes/minimal.css" asp-append-version="true" />
</head>
<body class="journal-theme">
    <header class="journal-header">
        <a asp-area="Blog" asp-page="/Index" class="journal-title">@TenantContext.RequiredTenant.Title</a>
        <span>@Localizer["Blog.LatestWriting"]</span>
    </header>
    <main class="journal-main">@RenderBody()@await RenderSectionAsync("Sidebar", required: false)</main>
    <footer class="journal-footer">&copy; @TenantContext.RequiredTenant.CreatedAt.Year @TenantContext.RequiredTenant.Title</footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
