@inject Blogify.Web.Services.TenantContext TenantContext
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @TenantContext.CurrentTenant?.Title</title>
    <link rel="stylesheet" href="~/css/themes/minimal.css" asp-append-version="true" />
</head>
<body class="bg-white text-stone-800 antialiased">
    <header class="border-b border-stone-200 py-6">
        <div class="max-w-2xl mx-auto px-4">
            <a asp-area="Blog" asp-page="/Index" class="no-underline text-stone-900">
                <h1 class="text-xl font-semibold tracking-tight">@TenantContext.CurrentTenant?.Title</h1>
            </a>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-10">
        @RenderBody()
        @RenderSection("Sidebar", required: false)
    </main>

    <footer class="border-t border-stone-200 py-6 mt-10">
        <div class="max-w-2xl mx-auto px-4 text-center text-sm text-stone-400">
            &copy; @TenantContext.CurrentTenant?.CreatedAt.Year — @TenantContext.CurrentTenant?.Title
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
