@model Blogify.Web.Areas.Blog.Pages.IndexModel
<header class="journal-intro">
    <h1>@Model.BlogTitle</h1>
</header>
@if (Model.Posts.Count == 0)
{
    <div class="empty-state">@Localizer["Blog.NoPosts"]</div>
}
else
{
    <div class="journal-list">
    @foreach (PostCardViewModel post in Model.Posts)
    {
        <article class="journal-entry">
            <time datetime="@post.PublishedAt.ToString("O")">@post.PublishedAt.ToString("D")</time>
            <div><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>
            @if (post.Excerpt is not null) { <p>@post.Excerpt</p> }
            @if (post.Categories.Count > 0 || post.Tags.Count > 0) { <div class="topic-links">@foreach (CategoryLinkViewModel cat in post.Categories) { <a asp-area="Blog" asp-page="/Category" asp-route-slug="@cat.Slug">@cat.Name</a> }@foreach (TagLinkViewModel tag in post.Tags) { <a asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug">@tag.Name</a> }</div> }</div>
        </article>
    }
    </div>
    await Html.RenderPartialAsync("_Pagination", Model.Pagination);
}
