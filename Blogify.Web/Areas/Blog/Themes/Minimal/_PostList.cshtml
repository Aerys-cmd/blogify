@model IReadOnlyList<Blogify.Web.Areas.Blog.Pages.PostCardViewModel>
<div class="border-t border-[#d9d9d2]">
    @foreach (PostCardViewModel post in Model)
    {
        <article class="grid gap-2 border-b border-[#d9d9d2] py-8 md:grid-cols-[150px_1fr] md:gap-8">
            <time class="text-xs text-[#686863]" datetime="@post.PublishedAt.ToString("O")">@post.PublishedAt.ToString("D")</time>
            <div>
                <h2 class="font-serif text-3xl leading-tight">
                    <a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="no-underline transition-colors hover:text-[#242f56] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@post.Title</a>
                </h2>
                @if (post.Excerpt is not null)
                {
                    <p class="mt-3 max-w-[54ch] leading-7 text-[#686863]">@post.Excerpt</p>
                }
                @if (post.Categories.Count > 0 || post.Tags.Count > 0)
                {
                    <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2">
                        @foreach (CategoryLinkViewModel cat in post.Categories)
                        {
                            <a asp-area="Blog" asp-page="/Category" asp-route-slug="@cat.Slug" class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@cat.Name</a>
                        }
                        @foreach (TagLinkViewModel tag in post.Tags)
                        {
                            <a asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug" class="text-xs font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@tag.Name</a>
                        }
                    </div>
                }
            </div>
        </article>
    }
</div>
