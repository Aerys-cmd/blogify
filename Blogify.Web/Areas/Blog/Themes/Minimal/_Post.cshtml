@model Blogify.Web.Areas.Blog.Pages.PostModel
<article class="article">
    <header class="article-header">
        <a asp-area="Blog" asp-page="/Index" class="back-link">← @Localizer["Blog.BackToPosts"]</a>
        <h1>@Model.PostTitle</h1><p class="date-line">@Localizer["Blog.Published", Model.PublishedAt.ToString("D")]</p>
        @if(Model.CategoryItems.Count>0){<div class="topic-links">@foreach(CategoryLinkViewModel cat in Model.CategoryItems){<a asp-area="Blog" asp-page="/Category" asp-route-slug="@cat.Slug">@cat.Name</a>}</div>}
    </header>
    @if(Model.CoverImageUrl is not null){<img src="@Model.CoverImageUrl" class="article-cover" alt="" />}
    <div class="prose">@Html.Raw(Model.PostContent)</div>
</article>
<partial name="_Comments" model="Model" />
