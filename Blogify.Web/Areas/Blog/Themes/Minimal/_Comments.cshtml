@model Blogify.Web.Areas.Blog.Pages.PostModel
<section class="mt-16 border-t border-[#181817] pt-7" aria-labelledby="comments-heading">
    <h2 id="comments-heading" class="font-serif text-3xl">@Localizer["Blog.Comments", Model.Comments.Count]</h2>
    @if (Model.Comments.Count == 0)
    {
        <p class="mt-4 text-[#686863]">@Localizer["Blog.NoComments"]</p>
    }
    @foreach (CommentViewModel comment in Model.Comments)
    {
        <article class="border-b border-[#d9d9d2] py-6">
            <header class="flex flex-wrap justify-between gap-3 text-xs">
                <strong>@comment.AuthorName</strong>
                <time class="text-[#686863]">@comment.CreatedAt.ToString("g")</time>
            </header>
            <p class="mt-3 leading-7">@comment.Content</p>
            @if (Model.IsAuthenticated)
            {
                <details class="mt-4">
                    <summary class="cursor-pointer text-xs font-bold text-[#242f56] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@Localizer["Blog.Reply"]</summary>
                    <form method="post" class="mt-4 grid gap-3">
                        <input type="hidden" name="Input.ParentCommentId" value="@comment.Id" />
                        <label class="text-xs font-bold" for="reply-@comment.Id">@Localizer["Blog.ReplyTo", comment.AuthorName]</label>
                        <input type="text" name="Input.Website" tabindex="-1" autocomplete="off" aria-hidden="true" class="sr-only" />
                        <textarea id="reply-@comment.Id" name="Input.Content" class="min-h-28 w-full border border-[#181817] bg-white px-3 py-3 focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#242f56]" maxlength="2000" required placeholder="@Localizer["Blog.ReplyPlaceholder"].Value"></textarea>
                        <button type="submit" class="min-h-11 w-max bg-[#181817] px-5 font-bold text-white transition-colors hover:bg-[#242f56] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@Localizer["Blog.PostReply"]</button>
                    </form>
                </details>
            }
            @foreach (CommentViewModel reply in comment.Replies)
            {
                <div class="mt-5 border-l border-[#181817] pl-4">
                    <header class="flex flex-wrap justify-between gap-3 text-xs">
                        <strong>@reply.AuthorName</strong>
                        <time class="text-[#686863]">@reply.CreatedAt.ToString("g")</time>
                    </header>
                    <p class="mt-3 leading-7">@reply.Content</p>
                </div>
            }
        </article>
    }
    <div class="mt-9 border-t border-[#d9d9d2] pt-7">
        @if (Model.IsAuthenticated)
        {
            <h3 class="font-serif text-2xl">@Localizer["Blog.LeaveComment"]</h3>
            <form method="post" class="mt-4 grid gap-3">
                <div asp-validation-summary="ModelOnly" class="text-[#B42318]"></div>
                <label asp-for="Input.Content" class="text-xs font-bold">@Localizer["Blog.YourComment"]</label>
                <input type="text" asp-for="Input.Website" tabindex="-1" autocomplete="off" aria-hidden="true" class="sr-only" />
                <textarea asp-for="Input.Content" class="min-h-32 w-full border border-[#181817] bg-white px-3 py-3 focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#242f56]" rows="5" maxlength="2000" placeholder="@Localizer["Blog.CommentPlaceholder"].Value"></textarea>
                <span asp-validation-for="Input.Content" class="text-[#B42318]"></span>
                <p class="text-sm text-[#686863]">@Localizer["Blog.CommentModerationNotice"]</p>
                <button type="submit" class="min-h-11 w-max bg-[#181817] px-5 font-bold text-white transition-colors hover:bg-[#242f56] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@Localizer["Blog.PostComment"]</button>
            </form>
        }
        else
        {
            <p><a href="@Model.LoginUrl" class="font-bold text-[#242f56] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">@Localizer["Blog.SignIn"]</a> @Localizer["Blog.SignInSuffix"]</p>
        }
    </div>
</section>
