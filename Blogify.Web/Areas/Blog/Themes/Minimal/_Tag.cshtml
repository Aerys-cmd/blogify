@model Blogify.Web.Areas.Blog.Pages.TagModel
<header class="mb-10">
    <a asp-area="Blog" asp-page="/Index" class="inline-flex min-h-11 items-center text-xs font-bold text-[#242f56] no-underline hover:text-[#181817] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#242f56]">&lt;- @Localizer["Blog.BackToPosts"]</a>
    <h1 class="mt-3 font-serif text-4xl leading-tight tracking-[-0.025em] md:text-6xl">@Localizer["Blog.TagHeading", Model.TagName]</h1>
</header>
@if (Model.Posts.Count == 0)
{
    <div class="py-16 text-[#686863]">@Localizer["Blog.NoTagPosts"]</div>
}
else
{
    <partial name="/Areas/Blog/Themes/Minimal/_PostList.cshtml" model="Model.Posts" />
    await Html.RenderPartialAsync("_Pagination", Model.Pagination);
}
