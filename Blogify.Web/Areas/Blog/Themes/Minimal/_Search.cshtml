@model Blogify.Web.Areas.Blog.Pages.SearchModel
<header class="mb-8">
    <h1 class="font-serif text-4xl leading-tight tracking-[-0.025em] md:text-6xl">@Localizer["Blog.Search"]</h1>
</header>
<form method="get" asp-area="Blog" asp-page="/Search" class="mb-8">
    <label class="sr-only" for="theme-search">@Localizer["Blog.Search"]</label>
    <input id="theme-search" class="min-h-12 w-full border border-[#181817] bg-white px-4 text-sm placeholder:text-[#686863] focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#242f56]" type="search" name="q" value="@Model.Query" placeholder="@Localizer["Blog.SearchPlaceholder"].Value" />
</form>
@if (Model.Posts.Count == 0)
{
    <div class="py-16 text-[#686863]">@Localizer["Blog.NoSearchResults"]</div>
}
else
{
    <partial name="/Areas/Blog/Themes/Minimal/_PostList.cshtml" model="Model.Posts" />
    await Html.RenderPartialAsync("_Pagination", Model.Pagination);
}
