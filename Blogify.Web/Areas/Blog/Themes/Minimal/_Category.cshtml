@model Blogify.Web.Areas.Blog.Pages.CategoryModel
<header class="journal-intro"><a asp-area="Blog" asp-page="/Index" class="back-link">← @Localizer["Blog.BackToPosts"]</a><h1>@Localizer["Blog.CategoryHeading", Model.CategoryName]</h1></header>
@if (Model.Posts.Count == 0) { <div class="empty-state">@Localizer["Blog.NoCategoryPosts"]</div> }
else { <div class="journal-list">@foreach(PostCardViewModel post in Model.Posts){<article class="journal-entry"><time>@post.PublishedAt.ToString("D")</time><div><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</div></article>}</div> }
