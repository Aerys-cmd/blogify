@model Blogify.Web.Areas.Blog.Pages.PostModel

<article>
    @if (Model.CoverImageUrl is not null)
    {
        <img src="@Model.CoverImageUrl" class="w-full aspect-video object-cover rounded-xl mb-6" alt="@Model.PostTitle" />
    }

    <header class="mb-6">
        <h1 class="text-3xl font-bold text-indigo-900 mb-2">@Model.PostTitle</h1>
        <p class="text-sm text-stone-400 mb-3">Published @Model.PublishedAt.ToString("MMMM d, yyyy")</p>
        @if (Model.CategoryItems.Count > 0)
        {
            <div class="flex flex-wrap gap-1">
                @foreach (CategoryLinkViewModel cat in Model.CategoryItems)
                {
                    <a asp-area="Blog"
                       asp-page="/Category"
                       asp-route-slug="@cat.Slug"
                       class="bg-indigo-100 text-indigo-700 rounded-full px-2 py-0.5 text-xs no-underline hover:bg-indigo-200">
                        @cat.Name
                    </a>
                }
            </div>
        }
    </header>

    <div class="prose prose-indigo max-w-none">
        @Html.Raw(Model.PostContent)
    </div>
</article>

<div class="mt-8 pt-6 border-t border-indigo-100">
    <a asp-area="Blog" asp-page="/Index" class="text-sm text-indigo-600 hover:text-indigo-800 underline">
        &larr; Back to all posts
    </a>
</div>

<section class="mt-10" aria-label="Comments">
    <h2 class="text-xl font-bold text-indigo-900 mb-6">Comments (@Model.Comments.Count)</h2>

    @foreach (CommentViewModel comment in Model.Comments)
    {
        <div class="mb-6">
            <div class="border border-indigo-100 rounded-xl p-4">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-semibold text-indigo-800">@comment.AuthorName</span>
                    <span class="text-xs text-stone-400">@comment.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</span>
                </div>
                <p class="text-stone-700 mb-2">@comment.Content</p>

                @if (Model.IsAuthenticated)
                {
                    <button type="button"
                            class="text-xs text-indigo-600 hover:text-indigo-800 underline"
                            data-reply-toggle="reply-@comment.Id">
                        Reply
                    </button>
                    <div id="reply-@comment.Id" class="hidden mt-3">
                        <form method="post">
                            <input type="hidden" name="Input.ParentCommentId" value="@comment.Id" />
                            <label for="reply-content-@comment.Id" class="sr-only">Reply to @comment.AuthorName</label>
                            <textarea id="reply-content-@comment.Id"
                                      name="Input.Content"
                                      class="w-full border border-indigo-200 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                      rows="2"
                                      maxlength="2000"
                                      placeholder="Write your reply…"
                                      required></textarea>
                            <button type="submit"
                                    class="mt-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-3 py-1.5 rounded-lg">
                                Post Reply
                            </button>
                        </form>
                    </div>
                }
            </div>

            @if (comment.Replies.Count > 0)
            {
                <div class="ml-6 mt-2 space-y-2">
                    @foreach (CommentViewModel reply in comment.Replies)
                    {
                        <div class="border border-indigo-50 bg-indigo-50 rounded-xl p-4">
                            <div class="flex justify-between items-center mb-1">
                                <span class="font-semibold text-indigo-700 text-sm">@reply.AuthorName</span>
                                <span class="text-xs text-stone-400">@reply.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</span>
                            </div>
                            <p class="text-stone-600 text-sm">@reply.Content</p>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (Model.Comments.Count == 0)
    {
        <p class="text-stone-400 text-sm">No comments yet. Be the first to share your thoughts!</p>
    }

    <div class="mt-8 pt-6 border-t border-indigo-100">
        @if (Model.IsAuthenticated)
        {
            <h3 class="text-lg font-semibold text-indigo-900 mb-4">Leave a comment</h3>
            <form method="post" class="space-y-3">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-3 text-sm"></div>
                <div>
                    <label asp-for="Input.Content" class="block text-sm font-medium text-stone-700 mb-1">Your comment</label>
                    <textarea asp-for="Input.Content"
                              class="w-full border border-indigo-200 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
                              rows="4"
                              maxlength="2000"
                              placeholder="Write your comment here…"></textarea>
                    <span asp-validation-for="Input.Content" class="text-red-600 text-xs mt-1 block"></span>
                </div>
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium">
                    Post Comment
                </button>
            </form>
        }
        else
        {
            <p class="text-stone-500 text-sm">
                <a asp-area="" asp-page="/Identity/Account/Login" asp-route-returnUrl="@Context.Request.Path"
                   class="text-indigo-600 hover:text-indigo-800 underline">Sign in</a>
                to leave a comment.
            </p>
        }
    </div>
</section>


