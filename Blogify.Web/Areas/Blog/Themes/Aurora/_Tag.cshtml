@model Blogify.Web.Areas.Blog.Pages.TagModel
<header class="magazine-category"><p class="magazine-kicker">@Localizer["Blog.Tags"]</p><h1>@Localizer["Blog.TagHeading", Model.TagName]</h1></header>
@if(Model.Posts.Count==0){<div class="empty-state">@Localizer["Blog.NoTagPosts"]</div>}else{<div class="magazine-grid">@foreach(PostCardViewModel post in Model.Posts){<article class="magazine-card"><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="magazine-card-image">@if(post.CoverImageUrl is not null){<img src="@post.CoverImageUrl" alt="" loading="lazy" />}else{<span aria-hidden="true">@post.Title.Substring(0,1).ToUpperInvariant()</span>}</a><time>@post.PublishedAt.ToString("D")</time><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Categories.Count>0||post.Tags.Count>0){<div class="topic-links">@foreach(CategoryLinkViewModel cat in post.Categories){<a asp-area="Blog" asp-page="/Category" asp-route-slug="@cat.Slug">@cat.Name</a>}@foreach(TagLinkViewModel tag in post.Tags){<a asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug">@tag.Name</a>}</div>}@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</article>}</div>await Html.RenderPartialAsync("_Pagination", Model.Pagination);}
