@model Blogify.Web.Areas.Blog.Pages.ArchiveModel
<header class="magazine-category"><p class="magazine-kicker">@Localizer["Blog.Archives"]</p><h1>@Localizer["Blog.ArchiveHeading", Model.MonthStart.ToString("MMMM yyyy")]</h1></header>
@if(Model.Posts.Count==0){<div class="empty-state">@Localizer["Blog.NoPosts"]</div>}else{<div class="magazine-grid">@foreach(PostCardViewModel post in Model.Posts){<article class="magazine-card"><time>@post.PublishedAt.ToString("D")</time><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</article>}</div>await Html.RenderPartialAsync("_Pagination", Model.Pagination);}

