@model Blogify.Web.Areas.Blog.Pages.CategoryModel
<header class="magazine-category"><p class="magazine-kicker">@Localizer["Blog.Categories"]</p><h1>@Localizer["Blog.CategoryHeading", Model.CategoryName]</h1></header>
@if(Model.Posts.Count==0){<div class="empty-state">@Localizer["Blog.NoCategoryPosts"]</div>}else{<div class="magazine-grid">@foreach(PostCardViewModel post in Model.Posts){<article class="magazine-card"><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug" class="magazine-card-image">@if(post.CoverImageUrl is not null){<img src="@post.CoverImageUrl" alt="" loading="lazy" />}else{<span aria-hidden="true">@post.Title.Substring(0,1).ToUpperInvariant()</span>}</a><time>@post.PublishedAt.ToString("D")</time><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</article>}</div>}
