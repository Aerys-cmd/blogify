@inject Blogify.Web.Services.TenantContext TenantContext
@inject Blogify.Web.Services.BlogBrandingService BrandingService
<!DOCTYPE html>
<html lang="@TenantContext.RequiredTenant.PublicLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    @await Html.PartialAsync("~/Areas/Blog/Themes/Shared/_BlogMeta.cshtml")
    <link rel="stylesheet" href="~/css/themes/aurora.css" asp-append-version="true" />
</head>
<body class="magazine-theme">
    @await Html.PartialAsync("~/Areas/Blog/Themes/Shared/_ThemePreviewBanner.cshtml")
    @{
        Blogify.Web.Services.BlogBrandingAssets branding = await BrandingService.GetAssetsAsync();
    }
    <header class="magazine-header">
        <div class="magazine-shell header-row">
            <a asp-area="Blog" asp-page="/Index" class="magazine-title magazine-brand">
                @if (!string.IsNullOrWhiteSpace(branding.LogoUrl))
                {
                    <img src="@branding.LogoUrl" alt="" class="magazine-logo" loading="lazy" decoding="async" />
                }
                <span>@TenantContext.RequiredTenant.Title</span>
            </a>
            <a asp-area="Blog" asp-page="/Index" class="magazine-home">@Localizer["Blog.Home"]</a>
        </div>
    </header>
    <main class="magazine-shell magazine-main">@RenderBody()@await RenderSectionAsync("Sidebar", required: false)</main>
    <footer class="magazine-footer"><div class="magazine-shell">&copy; @TenantContext.RequiredTenant.CreatedAt.Year @TenantContext.RequiredTenant.Title</div></footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
