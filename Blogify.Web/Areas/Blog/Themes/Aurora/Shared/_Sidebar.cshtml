@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel
<aside class="mt-16 bg-[#10162f] p-7 text-white">
    <h2 class="font-black">@Localizer["Blog.Discover"]</h2>
    <nav class="mt-4 flex flex-wrap gap-2" aria-label="@Localizer["Blog.Discover"].Value">
        <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Search">@Localizer["Blog.Search"]</a>
        <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Archives">@Localizer["Blog.Archives"]</a>
        <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Categories">@Localizer["Blog.Categories"]</a>
        <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Tags">@Localizer["Blog.Tags"]</a>
    </nav>
    <h2 class="mt-7 font-black">@Localizer["Blog.Categories"]</h2>
    @if (Model.Categories.Count == 0)
    {
        <p class="mt-3 text-[#ccd1e4]">@Localizer["Blog.NoCategories"]</p>
    }
    else
    {
        <nav class="mt-4 flex flex-wrap gap-2" aria-label="@Localizer["Blog.Categories"]">
            @foreach (CategoryLinkViewModel category in Model.Categories)
            {
                <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Category" asp-route-slug="@category.Slug">@category.Name</a>
            }
        </nav>
    }
    <h2 class="mt-7 font-black">@Localizer["Blog.Tags"]</h2>
    @if (Model.Tags.Count == 0)
    {
        <p class="mt-3 text-[#ccd1e4]">@Localizer["Blog.NoTags"]</p>
    }
    else
    {
        <nav class="mt-4 flex flex-wrap gap-2" aria-label="@Localizer["Blog.Tags"]">
            @foreach (TagLinkViewModel tag in Model.Tags)
            {
                <a class="rounded-full bg-[#2a3154] px-3 py-1.5 text-xs font-extrabold no-underline transition-colors hover:bg-[#39416b] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]" asp-area="Blog" asp-page="/Tag" asp-route-slug="@tag.Slug">@tag.Name</a>
            }
        </nav>
    }
</aside>
