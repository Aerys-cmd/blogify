@inject Blogify.Web.Services.TenantContext TenantContext
@model Blogify.Web.Areas.Blog.Pages.BlogSidebarViewModel

<div class="bg-indigo-50 rounded-xl p-4">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-indigo-700 mb-3">Categories</h2>
    @if (Model.Categories.Count == 0)
    {
        <p class="text-sm text-indigo-400">No categories yet.</p>
    }
    else
    {
        <div class="flex flex-wrap gap-2">
            @foreach (CategoryLinkViewModel category in Model.Categories)
            {
                <a asp-area="Blog"
                   asp-page="/Category"
                   asp-route-slug="@category.Slug"
                   class="bg-indigo-100 text-indigo-700 hover:bg-indigo-200 rounded-full px-3 py-1 text-xs font-medium no-underline transition-colors">
                    @category.Name
                </a>
            }
        </div>
    }
</div>
