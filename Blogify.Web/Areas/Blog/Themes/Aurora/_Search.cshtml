@model Blogify.Web.Areas.Blog.Pages.SearchModel
<header class="py-8">
    <p class="text-sm font-black text-[#4b57a8]">@Localizer["Blog.Discover"]</p>
    <h1 class="mt-2 text-5xl font-black leading-none tracking-[-0.035em] md:text-7xl">@Localizer["Blog.Search"]</h1>
</header>
<form method="get" asp-area="Blog" asp-page="/Search" class="mb-8 max-w-2xl">
    <label class="sr-only" for="theme-search">@Localizer["Blog.Search"]</label>
    <input id="theme-search" class="min-h-12 w-full border-2 border-[#10162f] bg-white px-4 font-bold text-ink placeholder:text-[#626970] focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#ee6b4d]" type="search" name="q" value="@Model.Query" placeholder="@Localizer["Blog.SearchPlaceholder"].Value" />
</form>
@if (Model.Posts.Count == 0)
{
    <div class="bg-[#10162f] px-5 py-20 text-center text-lg font-bold text-white">@Localizer["Blog.NoSearchResults"]</div>
}
else
{
    <partial name="/Areas/Blog/Themes/Aurora/_PostGrid.cshtml" model="Model.Posts" />
    await Html.RenderPartialAsync("_Pagination", Model.Pagination);
}
