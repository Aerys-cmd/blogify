@model Blogify.Web.Areas.Blog.Pages.SearchModel
<header class="magazine-category"><p class="magazine-kicker">@Localizer["Blog.Discover"]</p><h1>@Localizer["Blog.Search"]</h1></header>
<form method="get" asp-area="Blog" asp-page="/Search" class="mb-4"><input class="form-control" type="search" name="q" value="@Model.Query" placeholder="@Localizer["Blog.SearchPlaceholder"].Value" /></form>
@if(Model.Posts.Count==0){<div class="empty-state">@Localizer["Blog.NoSearchResults"]</div>}else{<div class="magazine-grid">@foreach(PostCardViewModel post in Model.Posts){<article class="magazine-card"><time>@post.PublishedAt.ToString("D")</time><h2><a asp-area="Blog" asp-page="/Post" asp-route-slug="@post.Slug">@post.Title</a></h2>@if(post.Excerpt is not null){<p>@post.Excerpt</p>}</article>}</div>await Html.RenderPartialAsync("_Pagination", Model.Pagination);}
