@model Blogify.Web.Areas.Blog.Pages.PostModel
<section class="mx-auto mt-20 max-w-[800px] border-t-4 border-[#10162f] pt-8" aria-labelledby="comments-heading">
    <h2 id="comments-heading" class="text-3xl font-black">@Localizer["Blog.Comments", Model.Comments.Count]</h2>
    @if (Model.Comments.Count == 0)
    {
        <p class="mt-4 text-[#626970]">@Localizer["Blog.NoComments"]</p>
    }
    @foreach (CommentViewModel comment in Model.Comments)
    {
        <article class="border-b border-[#d9dce7] py-6">
            <header class="flex flex-wrap justify-between gap-3 text-sm">
                <strong>@comment.AuthorName</strong>
                <time class="text-[#626970]">@comment.CreatedAt.ToString("g")</time>
            </header>
            <p class="mt-3 leading-7">@comment.Content</p>
            @if (Model.IsAuthenticated)
            {
                <details class="mt-4">
                    <summary class="cursor-pointer font-black text-[#4b57a8] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]">@Localizer["Blog.Reply"]</summary>
                    <form method="post" class="mt-4 grid gap-3">
                        <input type="hidden" name="Input.ParentCommentId" value="@comment.Id" />
                        <label class="font-black" for="reply-@comment.Id">@Localizer["Blog.ReplyTo", comment.AuthorName]</label>
                        <input type="text" name="Input.Website" tabindex="-1" autocomplete="off" aria-hidden="true" class="sr-only" />
                        <textarea id="reply-@comment.Id" name="Input.Content" class="min-h-28 w-full border-2 border-[#10162f] bg-white px-3 py-3 focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#ee6b4d]" maxlength="2000" required placeholder="@Localizer["Blog.ReplyPlaceholder"].Value"></textarea>
                        <button type="submit" class="min-h-11 w-max bg-[#ee6b4d] px-5 font-black text-[#10162f] transition-colors hover:bg-[#dfe985] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]">@Localizer["Blog.PostReply"]</button>
                    </form>
                </details>
            }
            @foreach (CommentViewModel reply in comment.Replies)
            {
                <div class="mt-5 bg-[#ececf6] p-4">
                    <header class="flex flex-wrap justify-between gap-3 text-sm">
                        <strong>@reply.AuthorName</strong>
                        <time class="text-[#626970]">@reply.CreatedAt.ToString("g")</time>
                    </header>
                    <p class="mt-3 leading-7">@reply.Content</p>
                </div>
            }
        </article>
    }
    <div class="mt-9 bg-[#ececf6] p-6">
        @if (Model.IsAuthenticated)
        {
            <h3 class="text-2xl font-black">@Localizer["Blog.LeaveComment"]</h3>
            <form method="post" class="mt-4 grid gap-3">
                <div asp-validation-summary="ModelOnly" class="text-[#B42318]"></div>
                <label asp-for="Input.Content" class="font-black">@Localizer["Blog.YourComment"]</label>
                <input type="text" asp-for="Input.Website" tabindex="-1" autocomplete="off" aria-hidden="true" class="sr-only" />
                <textarea asp-for="Input.Content" class="min-h-32 w-full border-2 border-[#10162f] bg-white px-3 py-3 focus:outline focus:outline-[3px] focus:outline-offset-2 focus:outline-[#ee6b4d]" rows="5" maxlength="2000" placeholder="@Localizer["Blog.CommentPlaceholder"].Value"></textarea>
                <span asp-validation-for="Input.Content" class="text-[#B42318]"></span>
                <p class="text-sm text-[#626970]">@Localizer["Blog.CommentModerationNotice"]</p>
                <button type="submit" class="min-h-11 w-max bg-[#ee6b4d] px-5 font-black text-[#10162f] transition-colors hover:bg-[#dfe985] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]">@Localizer["Blog.PostComment"]</button>
            </form>
        }
        else
        {
            <p><a href="@Model.LoginUrl" class="font-black text-[#4b57a8] no-underline hover:text-[#10162f] focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[#ee6b4d]">@Localizer["Blog.SignIn"]</a> @Localizer["Blog.SignInSuffix"]</p>
        }
    </div>
</section>
