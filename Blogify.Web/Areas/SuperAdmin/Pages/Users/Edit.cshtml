@page
@model Blogify.Web.Areas.SuperAdmin.Pages.Users.EditModel
@{
    ViewData["Title"] = $"Edit — {Model.CurrentEmail}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="SuperAdmin" asp-page="/Users/Index">Users</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <h1 class="h3 mb-0">Edit User</h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" type="email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.UserName" class="form-label">Username</label>
                        <input asp-for="Input.UserName" class="form-control" />
                        <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Input.IsSuperAdmin" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.IsSuperAdmin" class="form-check-label">SuperAdmin</label>
                        </div>
                        <div class="form-text text-muted">SuperAdmins can manage users and platform settings.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-area="SuperAdmin" asp-page="/Users/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
