@model PaginationModel

@if (Model.TotalPages > 1)
{
    string separator = Model.BaseUrl.Contains('?') ? "&" : "?";

    int windowSize = 2;
    int windowStart = Math.Max(2, Model.CurrentPage - windowSize);
    int windowEnd = Math.Min(Model.TotalPages - 1, Model.CurrentPage + windowSize);

    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link"
                   href="@(Model.CurrentPage > 1 ? $"{Model.BaseUrl}{separator}page={Model.CurrentPage - 1}" : "#")"
                   aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            <li class="page-item @(1 == Model.CurrentPage ? "active" : "")">
                <a class="page-link" href="@($"{Model.BaseUrl}{separator}page=1")">1</a>
            </li>

            @if (windowStart > 2)
            {
                <li class="page-item disabled" aria-hidden="true">
                    <span class="page-link">&hellip;</span>
                </li>
            }

            @for (int p = windowStart; p <= windowEnd; p++)
            {
                int pageNum = p;
                <li class="page-item @(pageNum == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@($"{Model.BaseUrl}{separator}page={pageNum}")">@pageNum</a>
                </li>
            }

            @if (windowEnd < Model.TotalPages - 1)
            {
                <li class="page-item disabled" aria-hidden="true">
                    <span class="page-link">&hellip;</span>
                </li>
            }

            @if (Model.TotalPages > 1)
            {
                <li class="page-item @(Model.TotalPages == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@($"{Model.BaseUrl}{separator}page={Model.TotalPages}")">@Model.TotalPages</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   href="@(Model.CurrentPage < Model.TotalPages ? $"{Model.BaseUrl}{separator}page={Model.CurrentPage + 1}" : "#")"
                   aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
}
