@using Blogify.Web.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    string? currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    bool isDashboardActive = string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase);
    bool isBlogsActive = currentPage?.StartsWith("/Blogs", StringComparison.OrdinalIgnoreCase) ?? false;
    bool isUsersActive = currentPage?.StartsWith("/Users", StringComparison.OrdinalIgnoreCase) ?? false;
}

<div class="offcanvas-lg offcanvas-start ba-sidebar"
     tabindex="-1"
     id="adminSidebar"
     aria-labelledby="adminSidebarLabel">
    <div class="ba-sidebar-inner bg-dark text-white d-flex flex-column">

        <div class="d-flex align-items-center justify-content-between px-3 py-3 border-bottom border-secondary">
            <a asp-area="SuperAdmin"
               asp-page="/Index"
               class="text-white text-decoration-none fw-semibold d-flex align-items-center gap-2"
               id="adminSidebarLabel">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                     class="text-danger" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/>
                </svg>
                Super Admin
            </a>
            <button type="button"
                    class="btn-close btn-close-white d-lg-none"
                    data-bs-dismiss="offcanvas"
                    aria-label="Close navigation"></button>
        </div>

        <nav class="flex-grow-1 py-2 px-2" aria-label="Super Admin navigation">
            <p class="ba-sidebar-section-label px-2 mb-1 mt-1">Navigation</p>

            <a class="nav-link d-flex align-items-center gap-2 px-2 py-2 rounded @(isDashboardActive ? "ba-nav-active" : "")"
               asp-area="SuperAdmin"
               asp-page="/Index"
               aria-current="@(isDashboardActive ? "page" : null)">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                     viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM2.5 14V7.707l5.5-5.5 5.5 5.5V14H10v-4a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5v4z"/>
                </svg>
                Dashboard
            </a>

            <a class="nav-link d-flex align-items-center gap-2 px-2 py-2 rounded @(isBlogsActive ? "ba-nav-active" : "")"
               asp-area="SuperAdmin"
               asp-page="/Blogs/Index"
               aria-current="@(isBlogsActive ? "page" : null)">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                     viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2z"/>
                    <path d="M5 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 5 8m0-2.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5M4 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0m0-2.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                </svg>
                Blogs
            </a>

            <a class="nav-link d-flex align-items-center gap-2 px-2 py-2 rounded @(isUsersActive ? "ba-nav-active" : "")"
               asp-area="SuperAdmin"
               asp-page="/Users/Index"
               aria-current="@(isUsersActive ? "page" : null)">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                     viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                </svg>
                Users
            </a>
        </nav>

        <div class="border-top border-secondary p-3">
            @if (SignInManager.IsSignedIn(User))
            {
                <div class="d-flex align-items-center gap-2 mb-2 overflow-hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                         class="flex-shrink-0 ba-sidebar-user-icon" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>
                    </svg>
                    <span class="small text-truncate ba-sidebar-username">@User.Identity?.Name</span>
                </div>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-grid">
                    <button type="submit" class="btn btn-sm btn-outline-light">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                             class="me-1" viewBox="0 0 16 16" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                            <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                        </svg>
                        Sign out
                    </button>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-sm btn-outline-light w-100">Sign in</a>
            }
        </div>

    </div>
</div>
