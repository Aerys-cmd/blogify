@page
@model Blogify.Web.Areas.SuperAdmin.Pages.Blogs.EditModel
@{
    ViewData["Title"] = $"Edit — {Model.TenantTitle}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="SuperAdmin" asp-page="/Blogs/Index">Blogs</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <h1 class="h3 mb-0">Edit Blog</h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label">Title</label>
                        <input asp-for="Input.Title" class="form-control" />
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Subdomain" class="form-label">Subdomain</label>
                        <div class="input-group">
                            <input asp-for="Input.Subdomain" class="form-control" />
                            <span class="input-group-text text-muted">.blogify.com</span>
                        </div>
                        <span asp-validation-for="Input.Subdomain" class="text-danger small"></span>
                        <div class="form-text">Lowercase letters, digits, and hyphens only.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-area="SuperAdmin" asp-page="/Blogs/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
