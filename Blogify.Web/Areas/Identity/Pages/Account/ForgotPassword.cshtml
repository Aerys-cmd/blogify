@page
@model Blogify.Web.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = @Localizer["Auth.ForgotPassword.Title"].Value;
}

<h4 class="mb-4 fw-semibold">@Localizer["Auth.ForgotPassword.Heading"]</h4>
<p class="text-muted small mb-4">@Localizer["Auth.ForgotPassword.Description"]</p>

@if (Model.EmailSent)
{
    <div class="alert alert-success">
        @Localizer["Auth.ForgotPassword.EmailSent"]
    </div>
    <div class="text-center mt-3">
        <a asp-page="./Login" class="btn btn-outline-secondary btn-sm">@Localizer["Auth.Login.Heading"]</a>
    </div>
}
else
{
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">@Localizer["Label.Email"]</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary">@Localizer["Auth.ForgotPassword.Submit"]</button>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
