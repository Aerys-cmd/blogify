<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Blogify</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blogify.Web.styles.css" asp-append-version="true" />
</head>
<body class="b-auth">
    <div class="b-auth-shell">
        <aside class="b-auth-story">
            <a href="/"><img src="~/blogify.svg" alt="Blogify" width="180" height="48" /></a>
            <div><h1>Make a place for your ideas.</h1><p>A focused workspace for writing clearly and publishing confidently.</p></div>
            <div class="b-auth-preview"><span>FIELD NOTES</span><strong>The work worth returning to</strong><i></i><i></i></div>
        </aside>
        <main class="b-auth-form">
            <div class="b-auth-form-inner">
                @RenderBody()
                <p class="text-muted small mt-4 mb-0">&copy; @DateTime.UtcNow.Year Blogify</p>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
