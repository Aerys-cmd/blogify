@page
@model Blogify.Web.Areas.BlogAdmin.Pages.Analytics.IndexModel
@{
    ViewData["Title"] = "Analytics";
}

<div class="mb-4">
    <h1 class="display-6">Analytics</h1>
    <p class="text-muted">Page view statistics for the last 7 and 30 days.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Views (7 days)</h2>
                <p class="display-6 mb-0">@Model.TotalViews7Days</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Views (30 days)</h2>
                <p class="display-6 mb-0">@Model.TotalViews30Days</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Unique Visitors (7 days)</h2>
                <p class="display-6 mb-0">@Model.UniqueVisitors7Days</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Unique Visitors (30 days)</h2>
                <p class="display-6 mb-0">@Model.UniqueVisitors30Days</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h2 class="h6 mb-0">Top Posts (last 30 days)</h2>
            </div>
            @if (Model.TopPosts.Count == 0)
            {
                <div class="card-body">
                    <p class="text-muted mb-0">No post views recorded yet.</p>
                </div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var post in Model.TopPosts)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-truncate me-2">@post.Title</span>
                            <span class="badge bg-primary rounded-pill">@post.Views</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h2 class="h6 mb-0">Top Referrers (last 30 days)</h2>
            </div>
            @if (Model.TopReferrers.Count == 0)
            {
                <div class="card-body">
                    <p class="text-muted mb-0">No referrer data recorded yet.</p>
                </div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var referrer in Model.TopReferrers)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-truncate me-2" title="@referrer.Referrer">@referrer.Referrer</span>
                            <span class="badge bg-secondary rounded-pill">@referrer.Views</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
