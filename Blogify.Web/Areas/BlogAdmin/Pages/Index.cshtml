@page
@model Blogify.Web.Areas.BlogAdmin.Pages.IndexModel
@{
    ViewData["Title"] = "Blog Admin";
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
}

<div class="mb-4">
    <h1 class="display-6">@Model.TenantTitle Admin</h1>
    <p class="text-muted">Manage content, design, and settings for this blog.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Total Posts</h2>
                <p class="display-6 mb-0">@Model.TotalPostCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Published</h2>
                <p class="display-6 mb-0">@Model.PublishedPostCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Drafts</h2>
                <p class="display-6 mb-0">@Model.DraftPostCount</p>
            </div>
        </div>
    </div>
</div>

<div class="list-group">
    <a class="list-group-item list-group-item-action" asp-area="BlogAdmin" asp-page="/Posts/Index" asp-route-blogSlug="@blogSlug">
        <strong>Posts</strong> - Create and manage posts for this blog.
    </a>
    <a class="list-group-item list-group-item-action" asp-area="BlogAdmin" asp-page="/Categories/Index" asp-route-blogSlug="@blogSlug">
        <strong>Categories</strong> - Organize posts into categories.
    </a>
</div>
