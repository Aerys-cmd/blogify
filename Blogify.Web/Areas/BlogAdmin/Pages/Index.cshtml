@page
@model Blogify.Web.Areas.BlogAdmin.Pages.IndexModel
@{
    ViewData["Title"] = Localizer["Page.Title.BlogAdmin.Dashboard"].Value;
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
}

<header class="b-page-header">
    <div><p class="b-page-context">@Model.TenantTitle</p><h1>@Localizer["BlogAdmin.Home.Heading"]</h1><p>@Localizer["BlogAdmin.Home.Description"]</p></div>
    <a class="btn btn-primary" asp-area="BlogAdmin" asp-page="/Posts/Create" asp-route-blogSlug="@blogSlug">@Localizer["BlogAdmin.Home.WritePost"]</a>
</header>
<section class="b-action-panel">
    <div><span class="b-status b-status-draft">@Localizer["BlogAdmin.Home.DraftCount", Model.DraftPostCount]</span><h2>@Localizer["BlogAdmin.Home.ContinueWriting"]</h2><p>@Localizer["BlogAdmin.Home.ContinueDescription"]</p></div>
    <a class="btn btn-dark" asp-area="BlogAdmin" asp-page="/Posts/Index" asp-route-blogSlug="@blogSlug">@Localizer["BlogAdmin.Home.OpenPosts"]</a>
</section>
<section class="b-section">
    <div class="b-section-heading"><h2>@Localizer["BlogAdmin.Home.Snapshot"]</h2><a asp-area="BlogAdmin" asp-page="/Analytics/Index" asp-route-blogSlug="@blogSlug">@Localizer["BlogAdmin.Home.ViewAnalytics"]</a></div>
    <div class="b-inline-metrics">
        <div><strong>@Model.PublishedPostCount</strong><span>@Localizer["BlogAdmin.Home.PublishedPosts"]</span></div>
        <div><strong>@Model.DraftPostCount</strong><span>@Localizer["BlogAdmin.Home.DraftsInProgress"]</span></div>
        <div><strong>@Model.TotalPostCount</strong><span>@Localizer["BlogAdmin.Home.TotalPosts"]</span></div>
    </div>
</section>
<section class="b-section">
    <div class="b-section-heading"><h2>@Localizer["BlogAdmin.Home.SetupTitle"]</h2><span>@Localizer["BlogAdmin.Home.NextSteps"]</span></div>
    <div class="b-checklist">
        <a asp-area="BlogAdmin" asp-page="/Posts/Create" asp-route-blogSlug="@blogSlug"><span>1</span><strong>@Localizer["BlogAdmin.Home.StepPost"]</strong><small>@Localizer["BlogAdmin.Home.StepPostHelp"]</small></a>
        <a asp-area="BlogAdmin" asp-page="/Themes/Index" asp-route-blogSlug="@blogSlug"><span>2</span><strong>@Localizer["BlogAdmin.Home.StepAppearance"]</strong><small>@Localizer["BlogAdmin.Home.StepAppearanceHelp"]</small></a>
        <a asp-area="BlogAdmin" asp-page="/Settings/Index" asp-route-blogSlug="@blogSlug"><span>3</span><strong>@Localizer["BlogAdmin.Home.StepDescription"]</strong><small>@Localizer["BlogAdmin.Home.StepDescriptionHelp"]</small></a>
    </div>
</section>
