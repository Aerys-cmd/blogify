@page
@using Blogify.Web.Areas.BlogAdmin.Pages.Themes
@model Blogify.Web.Areas.BlogAdmin.Pages.Themes.IndexModel
@{
    ViewData["Title"] = Localizer["Page.Title.BlogAdmin.Themes"].Value;
}

<header class="b-page-header">
    <div>
        <p class="b-page-context">@Localizer["Nav.Appearance"]</p>
        <h1>@Localizer["Themes.Heading"]</h1>
        <p>@Localizer["Themes.Description"]</p>
    </div>
</header>

@if (!ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
}

@if (Model.IsStoredThemeUnavailable)
{
    <div class="alert alert-warning">
        @Localizer["Themes.Unavailable", Model.StoredTheme, Model.CurrentTheme]
    </div>
}

<div class="b-theme-picker">
    @foreach (ThemeOptionViewModel theme in Model.AvailableThemes)
    {
        <article class="b-theme-option @(theme.Slug == Model.CurrentTheme ? "is-active" : "")">
            <div class="b-theme-preview">
                <img src="@theme.PreviewImageUrl"
                     alt="@theme.DisplayName"
                     loading="lazy" />
                @if (theme.Slug == Model.CurrentTheme)
                {
                    <span class="b-theme-active">@Localizer["Themes.Active"]</span>
                }
            </div>
            <div class="b-theme-option-body">
                <div>
                    <h2>@theme.DisplayName</h2>
                    <p>@theme.Description</p>
                </div>
                <form method="post">
                    <input type="hidden" name="SelectedTheme" value="@theme.Slug" />
                    <a href="@theme.PreviewUrl"
                       class="btn btn-outline-secondary w-100 mb-2"
                       target="_blank"
                       rel="noopener">
                        @Localizer["Themes.Preview"]
                    </a>
                    <button type="submit"
                            class="btn @(theme.Slug == Model.CurrentTheme ? "btn-outline-secondary" : "btn-primary") w-100"
                            @(theme.Slug == Model.CurrentTheme ? "disabled" : "")>
                        @(theme.Slug == Model.CurrentTheme ? Localizer["Themes.Current"] : Localizer["Themes.Activate"])
                    </button>
                </form>
            </div>
        </article>
    }
</div>
