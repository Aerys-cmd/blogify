@page
@model Blogify.Web.Areas.BlogAdmin.Pages.Media.IndexModel
@{
    ViewData["Title"] = "Media Library";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item active" aria-current="page">Media Library</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">Media Library</h1>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold d-flex align-items-center justify-content-between"
         role="button"
         data-bs-toggle="collapse"
         data-bs-target="#upload-panel"
         aria-expanded="false"
         aria-controls="upload-panel">
        <span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 class="me-1" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.646 5.146a.5.5 0 0 1 .708 0l2 2a.5.5 0 0 1-.708.708L8.5 6.707V10.5a.5.5 0 0 1-1 0V6.707L6.354 7.854a.5.5 0 1 1-.708-.708z"/>
                <path d="M4.406 3.342A5.53 5.53 0 0 1 8 2c2.69 0 4.923 2 5.166 4.579C14.758 6.804 16 8.137 16 9.773 16 11.569 14.502 13 12.687 13H3.781C1.708 13 0 11.366 0 9.318c0-1.763 1.266-3.223 2.942-3.593.143-.863.698-1.723 1.464-2.383"/>
            </svg>
            Upload File
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
             class="text-muted" viewBox="0 0 16 16" aria-hidden="true">
            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
        </svg>
    </div>
    <div class="collapse" id="upload-panel">
        <div class="card-body">
            <div id="upload-error" class="mb-3"></div>
            <form hx-post="?handler=Upload"
                  hx-encoding="multipart/form-data"
                  hx-target="#media-items-row"
                  hx-swap="afterbegin"
                  novalidate>
                <div class="mb-3">
                    <label for="upload-file-input" class="form-label fw-semibold">
                        Image File <span class="text-danger">*</span>
                    </label>
                    <input type="file" class="form-control" id="upload-file-input" name="file"
                           accept="image/jpeg,image/png,image/gif,image/webp" />
                    <div class="form-text">Accepted formats: JPEG, PNG, GIF, WebP. Maximum size: 10 MB.</div>
                </div>
                <button type="submit" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         class="me-1" viewBox="0 0 16 16" aria-hidden="true">
                        <path fill-rule="evenodd" d="M7.646 5.146a.5.5 0 0 1 .708 0l2 2a.5.5 0 0 1-.708.708L8.5 6.707V10.5a.5.5 0 0 1-1 0V6.707L6.354 7.854a.5.5 0 1 1-.708-.708z"/>
                        <path d="M4.406 3.342A5.53 5.53 0 0 1 8 2c2.69 0 4.923 2 5.166 4.579C14.758 6.804 16 8.137 16 9.773 16 11.569 14.502 13 12.687 13H3.781C1.708 13 0 11.366 0 9.318c0-1.763 1.266-3.223 2.942-3.593.143-.863.698-1.723 1.464-2.383"/>
                    </svg>
                    Upload
                </button>
            </form>
        </div>
    </div>
</div>

<div id="media-grid">
    <partial name="_MediaGrid" model="Model" />
</div>

