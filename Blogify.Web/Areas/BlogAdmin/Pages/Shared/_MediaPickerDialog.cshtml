@model Blogify.Web.Areas.BlogAdmin.Pages.Media.MediaPickerFieldVm
@{
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
}

<div class="modal fade" id="@Model.ModalId" tabindex="-1"
     aria-labelledby="@(Model.ModalId)-label" aria-hidden="true"
     hx-get="@Url.Page("/Media/Index", "MediaPicker", new { area = "BlogAdmin", blogSlug, targetInputId = Model.InputId, modalId = Model.ModalId })"
     hx-target="#@(Model.ModalId)-body"
     hx-swap="innerHTML"
     hx-trigger="show.bs.modal">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-fullscreen-md-down">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h2 class="modal-title h5" id="@(Model.ModalId)-label">
                    @(Model.ModalTitle ?? Localizer["Media.Picker.MediaLibrary"].Value)
                </h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="@Localizer["Action.Cancel"].Value"></button>
            </div>
            <div class="modal-body p-0 overflow-hidden" id="@(Model.ModalId)-body">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">@Localizer["Label.Loading"]</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2 justify-content-between">
                <span class="small text-muted media-picker-selection-status" id="@(Model.ModalId)-status"
                      aria-live="polite"></span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">
                        @Localizer["Action.Cancel"]
                    </button>
                    <button type="button" class="btn btn-primary btn-sm"
                            id="@(Model.ModalId)-confirm-btn"
                            data-picker-confirm
                            data-modal-id="@Model.ModalId"
                            data-target-input-id="@Model.InputId"
                            disabled>
                        @(Model.ModalTitle is not null ? Model.ModalTitle : Localizer["Media.Picker.UseThisImage"].Value)
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
