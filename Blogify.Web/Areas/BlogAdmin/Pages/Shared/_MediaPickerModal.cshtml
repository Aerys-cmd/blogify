@model Blogify.Web.Areas.BlogAdmin.Pages.Media.MediaPickerModalVm

@* Search bar + tab strip *@
<div class="px-3 pt-3">
    <input type="search" class="form-control form-control-sm mb-3"
           name="q" placeholder="Search by filename…"
           hx-get="/admin/Media?handler=MediaPicker&targetInputId=@Model.TargetInputId&modalId=@Model.ModalId"
           hx-target="#@(Model.ModalId)-body"
           hx-swap="innerHTML"
           hx-trigger="input changed delay:400ms, search"
           aria-label="Search media" />

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="@(Model.ModalId)-library-tab"
                    data-bs-toggle="tab" data-bs-target="#@(Model.ModalId)-library"
                    type="button" role="tab">Library</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="@(Model.ModalId)-upload-tab"
                    data-bs-toggle="tab" data-bs-target="#@(Model.ModalId)-upload"
                    type="button" role="tab">Upload</button>
        </li>
    </ul>
</div>

<div class="tab-content">
    @* Library tab *@
    <div class="tab-pane fade show active p-3" id="@(Model.ModalId)-library" role="tabpanel">
        @if (Model.Items.Count == 0)
        {
            <div class="text-center py-5">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                     class="text-muted mb-3" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M6.502 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/>
                    <path d="M14 14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM4 1a1 1 0 0 0-1 1v10l2.224-2.224a.5.5 0 0 1 .61-.075L8 11l2.157-3.02a.5.5 0 0 1 .76-.063L13 10V4.5h-2A1.5 1.5 0 0 1 9.5 3V1z"/>
                </svg>
                <p class="text-muted mb-0">No media files available.</p>
            </div>
        }
        else
        {
            <ul class="media-attachments" role="list">
                @foreach (MediaItemVm item in Model.Items)
                {
                    <li class="media-attachment">
                        <button type="button"
                                class="media-attachment-btn"
                                data-media-select
                                data-media-id="@item.Id"
                                data-url="@(item.ThumbnailUrl ?? item.Url)"
                                data-full-url="@item.Url"
                                data-alt-text="@(item.AltText ?? item.FileName)"
                                data-target="@Model.TargetInputId"
                                data-modal-id="@Model.ModalId"
                                aria-label="@Localizer["Aria.SelectMedia", item.FileName].Value">
                            @if (item.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                            {
                                <img src="@(item.ThumbnailUrl ?? item.Url)"
                                     alt="@(item.AltText ?? item.FileName)"
                                     class="media-attachment-thumb" />
                            }
                            else
                            {
                                <span class="media-attachment-icon" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1L14 4.5z"/>
                                    </svg>
                                </span>
                            }
                            <span class="media-attachment-check" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     viewBox="0 0 16 16">
                                    <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0"/>
                                </svg>
                            </span>
                            <span class="media-attachment-caption">@item.FileName</span>
                        </button>
                    </li>
                }
            </ul>

            @if (!string.IsNullOrEmpty(Model.Pager.NextCursor))
            {
                <div class="d-flex justify-content-center mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            hx-get="/admin/Media?handler=MediaPicker&targetInputId=@Model.TargetInputId&modalId=@Model.ModalId&cursor=@Model.Pager.NextCursor"
                            hx-target="#@(Model.ModalId)-body"
                            hx-swap="innerHTML">
                        Load more
                    </button>
                </div>
            }
        }
    </div>

    @* Upload tab *@
    <div class="tab-pane fade p-3" id="@(Model.ModalId)-upload" role="tabpanel">
        <div id="picker-upload-error-@Model.ModalId" class="mb-3"></div>
        <form hx-post="/admin/Media?handler=PickerUpload&targetInputId=@Model.TargetInputId&modalId=@Model.ModalId"
              hx-encoding="multipart/form-data"
              hx-target="#picker-upload-result-@Model.ModalId"
              hx-swap="afterbegin"
              hx-on:htmx:after-request="if(event.detail.successful) this.reset()"
              novalidate>
            <div class="mb-3">
                <label class="form-label fw-semibold">Image File <span class="text-danger">*</span></label>
                <input type="file" class="form-control" name="file"
                       accept="image/jpeg,image/png,image/gif,image/webp" />
                <div class="form-text">JPEG, PNG, GIF, WebP · max 10 MB.</div>
            </div>
            <button type="submit" class="btn btn-primary w-100">Upload</button>
        </form>
        <ul class="media-attachments mt-3" id="picker-upload-result-@Model.ModalId"></ul>
        <div class="mt-3 border-top pt-3">
            <button type="button" class="btn btn-outline-secondary btn-sm w-100"
                    hx-get="/admin/Media?handler=MediaPicker&targetInputId=@Model.TargetInputId&modalId=@Model.ModalId"
                    hx-target="#@(Model.ModalId)-body"
                    hx-swap="innerHTML">
                ← Refresh Library
            </button>
        </div>
    </div>
</div>
