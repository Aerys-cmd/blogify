@model Blogify.Web.Areas.BlogAdmin.Pages.Media.MediaPickerFieldVm

<input type="hidden" id="@Model.InputId" name="@Model.InputName"
       value="@(Model.CurrentMediaId.HasValue ? Model.CurrentMediaId.Value.ToString() : string.Empty)" />

@if (Model.CurrentMediaId.HasValue)
{
    <div id="@(Model.InputId)-preview" class="mb-2">
        <div class="pe-featured-image-set position-relative">
            <img src="@Model.CurrentThumbnailUrl" alt="@Localizer["Label.FeaturedImage"].Value"
                 class="img-fluid rounded border w-100"
                 style="max-height: 160px; object-fit: cover;" />
            <div class="pe-featured-image-overlay">
                <button type="button" class="btn btn-sm btn-light opacity-90"
                        data-bs-toggle="modal" data-bs-target="#@Model.ModalId">
                    @Localizer["Action.Edit"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger opacity-90"
                        data-picker-clear data-target-input-id="@Model.InputId">
                    @Localizer["Action.Delete"]
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div id="@(Model.InputId)-preview" class="d-none mb-2">
        <div class="pe-featured-image-set position-relative">
            <img src="" alt="@Localizer["Label.FeaturedImage"].Value"
                 class="img-fluid rounded border w-100"
                 style="max-height: 160px; object-fit: cover;" />
            <div class="pe-featured-image-overlay">
                <button type="button" class="btn btn-sm btn-light opacity-90"
                        data-bs-toggle="modal" data-bs-target="#@Model.ModalId">
                    @Localizer["Action.Edit"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger opacity-90"
                        data-picker-clear data-target-input-id="@Model.InputId">
                    @Localizer["Action.Delete"]
                </button>
            </div>
        </div>
    </div>

    <button type="button"
            id="@(Model.InputId)-empty-btn"
            class="pe-featured-image-drop w-100 @(Model.CurrentMediaId.HasValue ? "d-none" : "")"
            data-bs-toggle="modal" data-bs-target="#@Model.ModalId">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
             class="mb-1" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M6.502 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/>
            <path d="M14 14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM4 1a1 1 0 0 0-1 1v10l2.224-2.224a.5.5 0 0 1 .61-.075L8 11l2.157-3.02a.5.5 0 0 1 .76-.063L13 10V4.5h-2A1.5 1.5 0 0 1 9.5 3V1z"/>
        </svg>
        <span class="d-block">@Localizer["Label.FeaturedImage"]</span>
    </button>
}

@if (!string.IsNullOrEmpty(Model.RecommendedDimensionsHint))
{
    <p class="form-text mb-0">@Model.RecommendedDimensionsHint</p>
    <p class="form-text">@Localizer["Label.FeaturedImage.Min"]</p>
}

<button type="button"
        id="@(Model.InputId)-clear"
        class="btn btn-link btn-sm p-0 text-danger mt-1 @(!Model.CurrentMediaId.HasValue ? "d-none" : "")"
        data-picker-clear
        data-target-input-id="@Model.InputId">
    @Localizer["Action.Delete"]
</button>
