 @model Blogify.Web.Areas.BlogAdmin.Pages.Media.MediaPickerFieldVm

<input type="hidden" id="@Model.InputId" name="@Model.InputName" value="@Model.CurrentUrl" />

<div id="@(Model.InputId)-preview" class="mb-2 @(string.IsNullOrEmpty(Model.CurrentUrl) ? "d-none" : "")">
    <img src="@Model.CurrentUrl" alt="Featured image preview"
         class="img-fluid rounded border" style="max-height: 160px; object-fit: cover;" />
</div>

<div class="d-flex align-items-center gap-2 flex-wrap">
    <button type="button" class="btn btn-outline-secondary btn-sm"
            data-bs-toggle="modal"
            data-bs-target="#@Model.ModalId"
            hx-get="/admin/Media?handler=MediaPicker&targetInputId=@Model.InputId&modalId=@Model.ModalId"
            hx-target="#@(Model.ModalId)-body"
            hx-swap="innerHTML"
            hx-trigger="click">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
             class="me-1" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M6.502 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/>
            <path d="M14 14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM4 1a1 1 0 0 0-1 1v10l2.224-2.224a.5.5 0 0 1 .61-.075L8 11l2.157-3.02a.5.5 0 0 1 .76-.063L13 10V4.5h-2A1.5 1.5 0 0 1 9.5 3V1z"/>
        </svg>
        Choose from Library
    </button>
</div>

<div class="modal fade" id="@Model.ModalId" tabindex="-1"
     aria-labelledby="@(Model.ModalId)-label" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="@(Model.ModalId)-label">Media Library</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="@(Model.ModalId)-body">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const hiddenInput = document.getElementById('@Model.InputId');
        const previewDiv = document.getElementById('@(Model.InputId)-preview');
        const modalEl = document.getElementById('@Model.ModalId');

        document.addEventListener('mediaSelected', function (e) {
            if (e.detail.targetInputId !== '@Model.InputId') { return; }
            hiddenInput.value = e.detail.url;
            if (previewDiv) {
                const img = previewDiv.querySelector('img');
                if (img) { img.src = e.detail.url; }
                previewDiv.classList.remove('d-none');
            }
            if (modalEl) {
                const bsModal = bootstrap.Modal.getInstance(modalEl);
                if (bsModal) { bsModal.hide(); }
            }
        });
    })();
</script>

