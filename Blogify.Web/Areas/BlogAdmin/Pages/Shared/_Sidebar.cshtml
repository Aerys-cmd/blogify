@using Blogify.Web.Models
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<ApplicationUser> SignInManager
@inject Blogify.Web.Services.TenantContext TenantCtx
@inject Blogify.Web.Services.BlogBrandingService BrandingService
@inject Blogify.Web.Services.IBlogPermissionService PermissionService
@inject Blogify.Web.Services.IAccessibleBlogService AccessibleBlogService
@{
    string? page = ViewContext.RouteData.Values["page"]?.ToString();
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
    string blogTitle = TenantCtx.CurrentTenant?.Title ?? Localizer["Page.Title.BlogAdmin.Dashboard"].Value;
    string? userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool canManageUsers = userId is not null && await PermissionService.CanManageUsersAsync(userId, TenantCtx.RequiredTenant.Id);
    IReadOnlyList<Blogify.Web.Services.AccessibleBlog> blogs = userId is null
        ? []
        : await AccessibleBlogService.GetForUserAsync(userId, Context.Request.Scheme, Context.Request.Host);
    Blogify.Web.Services.AccessibleBlog? currentBlog = blogs.FirstOrDefault(blog => blog.Subdomain == blogSlug);
    Blogify.Web.Services.BlogBrandingAssets branding = await BrandingService.GetAssetsAsync();
    string Active(string prefix) => page?.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) == true ? "ba-nav-active" : "";
    string? Current(string prefix) => page?.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) == true ? "page" : null;
}
<div class="offcanvas-lg offcanvas-start ba-sidebar" tabindex="-1" id="adminSidebar" aria-labelledby="adminSidebarLabel">
    <div class="ba-sidebar-inner d-flex flex-column">
        <div class="ba-blog-switcher dropdown">
            <button class="ba-blog-switcher-button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="adminSidebarLabel">
                <img src="@(branding.LogoUrl ?? Url.Content("~/blogify-mark.svg"))" alt="" width="30" height="30" class="ba-blog-switcher-logo" />
                <span><small>@Localizer["Sidebar.CurrentBlog"]</small><strong>@blogTitle</strong></span>
            </button>
            <button type="button" class="btn-close d-lg-none" data-bs-dismiss="offcanvas" aria-label="@Localizer["Aria.CloseNavigation"].Value"></button>
            <div class="dropdown-menu ba-blog-menu">
                <h2 class="dropdown-header">@Localizer["Sidebar.SwitchBlog"]</h2>
                @foreach (Blogify.Web.Services.AccessibleBlog blog in blogs)
                {
                    <a class="dropdown-item @(blog.Subdomain == blogSlug ? "active" : "")" href="/app/admin/@blog.Subdomain" aria-current="@(blog.Subdomain == blogSlug ? "page" : null)">
                        <span>@blog.Title<small>@($"{blog.Subdomain}.blogify.com")</small></span>
                        @if (blog.Subdomain == blogSlug) { <span aria-hidden="true">✓</span> }
                    </a>
                }
                <div class="dropdown-divider"></div>
                @if (currentBlog is not null)
                {
                    <a class="dropdown-item" href="@currentBlog.PublicUrl" target="_blank" rel="noopener">@Localizer["Sidebar.ViewBlog"]</a>
                }
                <a class="dropdown-item" href="/dashboard">@Localizer["Sidebar.AllBlogs"]</a>
                <a class="dropdown-item" asp-page="/Dashboard/CreateBlog" asp-area="">@Localizer["Action.CreateBlog"]</a>
            </div>
        </div>

        <div class="ba-compose-wrap">
            <a class="ba-compose-link" asp-area="BlogAdmin" asp-page="/Posts/Create" asp-route-blogSlug="@blogSlug">
                <span aria-hidden="true">＋</span>@Localizer["Action.NewPost"]
            </a>
        </div>

        <nav class="flex-grow-1 ba-sidebar-nav" aria-label="@Localizer["Aria.AdminNavigation"].Value">
            <p class="ba-sidebar-section-label">@Localizer["Sidebar.Workspace"]</p>
            <a class="ba-nav-link @Active("/Index")" aria-current="@Current("/Index")" asp-area="BlogAdmin" asp-page="/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">⌂</span>@Localizer["Nav.Overview"]</a>
            <a class="ba-nav-link @Active("/Posts")" aria-current="@Current("/Posts")" asp-area="BlogAdmin" asp-page="/Posts/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">▤</span>@Localizer["Nav.Posts"]</a>
            <a class="ba-nav-link @Active("/Media")" aria-current="@Current("/Media")" asp-area="BlogAdmin" asp-page="/Media/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">▧</span>@Localizer["Nav.Media"]</a>
            <a class="ba-nav-link @Active("/Analytics")" aria-current="@Current("/Analytics")" asp-area="BlogAdmin" asp-page="/Analytics/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">↗</span>@Localizer["Nav.Analytics"]</a>
            <p class="ba-sidebar-section-label">@Localizer["Sidebar.Manage"]</p>
            <a class="ba-nav-link @Active("/Themes")" aria-current="@Current("/Themes")" asp-area="BlogAdmin" asp-page="/Themes/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">◐</span>@Localizer["Nav.Appearance"]</a>
            <a class="ba-nav-link @Active("/Categories")" aria-current="@Current("/Categories")" asp-area="BlogAdmin" asp-page="/Categories/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">#</span>@Localizer["Nav.Categories"]</a>
            <a class="ba-nav-link @Active("/Tags")" aria-current="@Current("/Tags")" asp-area="BlogAdmin" asp-page="/Tags/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">⌁</span>@Localizer["Nav.Tags"]</a>
            @if (canManageUsers)
            {
                <a class="ba-nav-link @Active("/Members")" aria-current="@Current("/Members")" asp-area="BlogAdmin" asp-page="/Members/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">♙</span>@Localizer["Nav.Members"]</a>
            }
            <a class="ba-nav-link @Active("/Settings")" aria-current="@Current("/Settings")" asp-area="BlogAdmin" asp-page="/Settings/Index" asp-route-blogSlug="@blogSlug"><span aria-hidden="true">⚙</span>@Localizer["Nav.Settings"]</a>
        </nav>

        <div class="ba-sidebar-footer">
            <partial name="_LanguageSwitcher" />
            @if (SignInManager.IsSignedIn(User))
            {
                <div class="dropdown dropup">
                    <button class="ba-account-button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="ba-account-avatar" aria-hidden="true">@((User.Identity?.Name ?? "?")[0].ToString().ToUpperInvariant())</span>
                        <span><strong>@Localizer["Sidebar.Account"]</strong><small>@User.Identity?.Name</small></span>
                    </button>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="/dashboard">@Localizer["Sidebar.AllBlogs"]</a>
                        <div class="dropdown-divider"></div>
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                            <button type="submit" class="dropdown-item">@Localizer["Nav.SignOut"]</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
