@using Blogify.Web.Models
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<ApplicationUser> SignInManager
@inject Blogify.Web.Services.TenantContext TenantCtx
@inject Blogify.Web.Services.IBlogPermissionService PermissionService
@{
    string? page = ViewContext.RouteData.Values["page"]?.ToString();
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
    string blogTitle = TenantCtx.CurrentTenant?.Title ?? "Blog Admin";
    string? userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool canManageUsers = userId is not null && await PermissionService.CanManageUsersAsync(userId, TenantCtx.RequiredTenant.Id);
    string Active(string prefix) => page?.StartsWith(prefix, StringComparison.OrdinalIgnoreCase) == true ? "ba-nav-active" : "";
}
<div class="offcanvas-lg offcanvas-start ba-sidebar" tabindex="-1" id="adminSidebar" aria-labelledby="adminSidebarLabel">
    <div class="ba-sidebar-inner d-flex flex-column">
        <div class="ba-blog-switcher">
            <a asp-area="BlogAdmin" asp-page="/Index" asp-route-blogSlug="@blogSlug" id="adminSidebarLabel">
                <img src="~/blogify-mark.svg" alt="" width="32" height="32" />
                <span><small>Current blog</small><strong>@blogTitle</strong></span>
            </a>
            <button type="button" class="btn-close d-lg-none" data-bs-dismiss="offcanvas" aria-label="Close navigation"></button>
        </div>
        <div class="px-3">
            <a class="btn btn-primary w-100" asp-area="BlogAdmin" asp-page="/Posts/Create" asp-route-blogSlug="@blogSlug">Write new post</a>
        </div>
        <nav class="flex-grow-1 px-2 py-3" aria-label="Admin navigation">
            <a class="ba-nav-link @Active("/Index")" asp-area="BlogAdmin" asp-page="/Index" asp-route-blogSlug="@blogSlug">Overview</a>
            <p class="ba-sidebar-section-label">Create</p>
            <a class="ba-nav-link @Active("/Posts")" asp-area="BlogAdmin" asp-page="/Posts/Index" asp-route-blogSlug="@blogSlug">Posts</a>
            <a class="ba-nav-link @Active("/Media")" asp-area="BlogAdmin" asp-page="/Media/Index" asp-route-blogSlug="@blogSlug">Media</a>
            <p class="ba-sidebar-section-label">Grow</p>
            <a class="ba-nav-link @Active("/Analytics")" asp-area="BlogAdmin" asp-page="/Analytics/Index" asp-route-blogSlug="@blogSlug">Analytics</a>
            <p class="ba-sidebar-section-label">Manage</p>
            <a class="ba-nav-link @Active("/Themes")" asp-area="BlogAdmin" asp-page="/Themes/Index" asp-route-blogSlug="@blogSlug">Appearance</a>
            <a class="ba-nav-link @Active("/Categories")" asp-area="BlogAdmin" asp-page="/Categories/Index" asp-route-blogSlug="@blogSlug">Categories</a>
            @if (canManageUsers)
            {
                <a class="ba-nav-link @Active("/Members")" asp-area="BlogAdmin" asp-page="/Members/Index" asp-route-blogSlug="@blogSlug">@Localizer["Nav.Members"]</a>
            }
            <a class="ba-nav-link @Active("/Settings")" asp-area="BlogAdmin" asp-page="/Settings/Index" asp-route-blogSlug="@blogSlug">@Localizer["Nav.Settings"]</a>
        </nav>
        <div class="ba-sidebar-footer">
            <a href="/dashboard">All blogs</a>
            @if (SignInManager.IsSignedIn(User))
            {
                <span title="@User.Identity?.Name">@User.Identity?.Name</span>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post"><button type="submit" class="btn btn-link">Sign out</button></form>
            }
        </div>
    </div>
</div>
