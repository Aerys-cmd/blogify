@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Blog Admin · Blogify</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blogify.Web.styles.css" asp-append-version="true" />
</head>
<body class="ba-layout bg-light"
      hx-headers='{"RequestVerificationToken": "@Antiforgery.GetAndStoreTokens(Context).RequestToken"}'>

    <div id="ba-loader" aria-hidden="true"></div>

    <div class="d-flex">
        <partial name="_Sidebar" />

        <div class="ba-main flex-grow-1 d-flex flex-column min-vh-100">

            <header class="d-flex d-lg-none align-items-center bg-dark px-3 py-2 sticky-top shadow-sm">
                <button class="btn btn-dark border-0 p-1 me-2"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#adminSidebar"
                        aria-controls="adminSidebar"
                        aria-label="Open navigation">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                         class="text-white" viewBox="0 0 16 16" aria-hidden="true">
                        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
                    </svg>
                </button>
                <a asp-area="BlogAdmin" asp-page="/Index" asp-route-blogSlug="@blogSlug" class="text-white text-decoration-none fw-semibold">
                    <span class="text-warning">&#9998;</span> Blog Admin
                </a>
                <div class="ms-auto">
                    <partial name="_LanguageSwitcher" />
                </div>
            </header>

            <main class="container-fluid py-4 flex-grow-1">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/htmx/htmx.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script type="module" src="~/js/media-picker.js" asp-append-version="true"></script>
    <script type="module" src="~/js/media-picker-upload.js" asp-append-version="true"></script>
    <script type="module" src="~/js/media-detail-autosave.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/blogadmin-layout.js" asp-append-version="true"></script>
</body>
</html>
