@model Blogify.Web.Areas.BlogAdmin.Pages.Media.MediaDetailVm
@{
    string FormatFileSize(long bytes) => bytes >= 1_048_576
        ? $"{bytes / 1_048_576.0:F1} MB"
        : $"{bytes / 1024.0:F0} KB";
}

@* Panel header *@
<div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom bg-light">
    <span class="small fw-semibold text-truncate me-2" title="@Model.FileName">@Localizer["Label.AttachmentDetails"]</span>
    <button type="button" class="btn-close btn-sm flex-shrink-0"
            id="close-attachment-details" aria-label="@Localizer["Aria.CloseDetailsPanel"].Value"></button>
</div>

@* Image preview *@
@if (Model.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
{
    <div class="d-flex align-items-center justify-content-center bg-dark"
         style="min-height: 180px; max-height: 220px; overflow: hidden;">
        <img src="@(Model.ThumbnailUrl ?? Model.Url)" alt="@(Model.AltText ?? Model.FileName)"
             class="img-fluid" style="max-height: 220px; object-fit: contain;" />
    </div>
}
else
{
    <div class="d-flex align-items-center justify-content-center bg-light" style="height: 140px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor"
             class="text-secondary" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1L14 4.5z"/>
        </svg>
    </div>
}

<div class="p-3">

    @* File info *@
    <dl class="row small mb-3">
        <dt class="col-5 text-muted fw-normal">@Localizer["Label.File"]</dt>
        <dd class="col-7 text-truncate mb-1 fw-semibold" title="@Model.FileName">@Model.FileName</dd>

        <dt class="col-5 text-muted fw-normal">@Localizer["Label.Type"]</dt>
        <dd class="col-7 mb-1">@Model.ContentType</dd>

        <dt class="col-5 text-muted fw-normal">@Localizer["Label.Size"]</dt>
        <dd class="col-7 mb-1">@FormatFileSize(Model.SizeBytes)</dd>

        @if (Model.WidthPx.HasValue && Model.HeightPx.HasValue)
        {
            <dt class="col-5 text-muted fw-normal">@Localizer["Label.Dimensions"]</dt>
            <dd class="col-7 mb-1">@Model.WidthPx × @Model.HeightPx px</dd>
        }

        <dt class="col-5 text-muted fw-normal">@Localizer["Label.Uploaded"]</dt>
        <dd class="col-7 mb-1">@Model.UploadedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")</dd>
    </dl>

    @* Autosaving metadata form *@
    <div class="mb-3 border-top pt-3">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="small fw-semibold">@Localizer["Label.AltText"]</span>
            <span class="small text-muted media-detail-save-status" id="meta-save-status-@Model.Id"
                  aria-live="polite"></span>
        </div>

        <input type="hidden" name="id" id="meta-id-@Model.Id" value="@Model.Id" />

        <div class="mb-2">
            <input type="text" class="form-control form-control-sm media-detail-autosave"
                   id="meta-alt-@Model.Id"
                   data-field="altText"
                   data-media-id="@Model.Id"
                   value="@Model.AltText"
                   placeholder="@Localizer["Placeholder.AltText"].Value"
                   maxlength="500"
                   aria-label="@Localizer["Label.AltText"].Value" />
            <div class="d-flex justify-content-between mt-1">
                <div class="form-text small">@Localizer["Label.AltText"]</div>
                <span class="form-text small media-char-count" data-max="500" data-input="meta-alt-@Model.Id">
                    @(Model.AltText?.Length ?? 0)/500
                </span>
            </div>
        </div>

        <div class="mb-2">
            <label for="meta-title-@Model.Id" class="form-label small fw-semibold mb-1">@Localizer["Label.Title"]</label>
            <input type="text" class="form-control form-control-sm media-detail-autosave"
                   id="meta-title-@Model.Id"
                   data-field="title"
                   data-media-id="@Model.Id"
                   value="@Model.Title"
                   placeholder="@Localizer["Placeholder.MediaTitle"].Value"
                   maxlength="255" />
        </div>

        <div class="mb-2">
            <label for="meta-desc-@Model.Id" class="form-label small fw-semibold mb-1">@Localizer["Label.Description"]</label>
            <textarea class="form-control form-control-sm media-detail-autosave"
                      id="meta-desc-@Model.Id"
                      data-field="description"
                      data-media-id="@Model.Id"
                      rows="3"
                      placeholder="@Localizer["Placeholder.MediaDescription"].Value"
                      maxlength="2000">@Model.Description</textarea>
        </div>
    </div>

    @* URL copy *@
    <div class="mb-3">
        <label class="form-label small fw-semibold mb-1">@Localizer["Label.FileUrl"]</label>
        <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace small"
                   id="detail-url-@Model.Id" value="@Model.Url" readonly />
            <button type="button" class="btn btn-outline-secondary"
                    data-copy-target="detail-url-@Model.Id">
                @Localizer["Action.Copy"]
            </button>
        </div>
    </div>

    @* Usage *@
    @if (Model.UsedInPosts.Count > 0)
    {
        <div class="mb-3">
            <p class="small fw-semibold mb-1">@Localizer["Media.UsedAsCoverIn"]</p>
            <ul class="list-unstyled mb-0">
                @foreach (string postTitle in Model.UsedInPosts)
                {
                    <li class="small text-muted">• @postTitle</li>
                }
            </ul>
        </div>
    }

    @* Delete — danger zone with Bootstrap confirmation modal *@
    <div class="border-top pt-3 mt-1">
        <p class="small text-muted mb-2">@Localizer["Media.Detail.DeleteTitle"]</p>
        @if (Model.UsedInPosts.Count > 0)
        {
            <div class="alert alert-warning py-2 px-3 small mb-2" role="alert">
                @string.Format(Localizer["Media.Detail.DeleteConfirmUsed"].Value, Model.UsedInPosts.Count)
            </div>
        }
        <button type="button"
                class="btn btn-outline-danger btn-sm w-100"
                data-bs-toggle="modal"
                data-bs-target="#media-delete-confirm-@Model.Id">
            @Localizer["Action.DeletePermanently"]
        </button>
    </div>
</div>

@* ── Delete confirmation modal ───────────────────────────────────────── *@
<div class="modal fade" id="media-delete-confirm-@Model.Id" tabindex="-1"
     aria-labelledby="media-delete-label-@Model.Id" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h2 class="modal-title h6" id="media-delete-label-@Model.Id">
                    @Localizer["Media.Detail.DeleteTitle"]
                </h2>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"
                        aria-label="@Localizer["Action.Cancel"].Value"></button>
            </div>
            <div class="modal-body small">
                @string.Format(Localizer["Media.Detail.DeleteConfirmBody"].Value, Model.FileName)
                @if (Model.UsedInPosts.Count > 0)
                {
                    <div class="alert alert-warning py-1 px-2 small mt-2 mb-0" role="alert">
                        @string.Format(Localizer["Media.Detail.DeleteConfirmUsed"].Value, Model.UsedInPosts.Count)
                    </div>
                }
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    @Localizer["Action.Cancel"]
                </button>
                <button type="button"
                        class="btn btn-danger btn-sm"
                        data-bs-dismiss="modal"
                        hx-post="?handler=Delete&id=@Model.Id"
                        hx-target="[data-media-id='@Model.Id']"
                        hx-swap="outerHTML"
                        hx-on:htmx:after-request="if(event.detail.successful) { window.closeAttachmentPanel && window.closeAttachmentPanel(); }">
                    @Localizer["Action.DeletePermanently"]
                </button>
            </div>
        </div>
    </div>
</div>

