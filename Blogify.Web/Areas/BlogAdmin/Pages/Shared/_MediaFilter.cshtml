@model Blogify.Web.Areas.BlogAdmin.Pages.Media.IndexModel

<div class="d-flex flex-column gap-3">
    @* Search *@
    <div>
        <label class="form-label small fw-semibold mb-1">@Localizer["Action.Search"]</label>
        <input type="search" class="form-control form-control-sm"
               name="q" id="active-q-filter" value="@Model.SearchQuery"
               placeholder="@Localizer["Placeholder.SearchMedia"].Value"
               hx-get="?handler=Search"
               hx-target="#media-content"
               hx-swap="innerHTML"
               hx-trigger="input changed delay:400ms, search"
               hx-include="[name='type'],[name='month']"
               aria-label="@Localizer["Aria.SearchMedia"].Value" />
    </div>

    @* Type filter *@
    <div>
        <p class="form-label small fw-semibold mb-2">@Localizer["Label.Type"]</p>
        @{
            (string Value, string Label)[] typeOptions =
            [
                ("", Localizer["Media.Picker.TypeAll"].Value),
                ("image", Localizer["Label.Images"].Value),
                ("document", Localizer["Label.Documents"].Value)
            ];
        }
        <div class="d-flex flex-column gap-1">
            @foreach ((string value, string label) in typeOptions)
            {
                string radioId = $"type-{(value == "" ? "all" : value)}";
                bool isActive = Model.TypeFilter == value || (string.IsNullOrEmpty(value) && string.IsNullOrEmpty(Model.TypeFilter));
                <div class="form-check">
                    <input class="form-check-input" type="radio"
                           name="type" id="@radioId" value="@value"
                           checked="@(isActive ? "checked" : null)"
                           hx-get="?handler=Search"
                           hx-target="#media-content"
                           hx-swap="innerHTML"
                           hx-include="[name='q'],[name='month']"
                           hx-trigger="change" />
                    <label class="form-check-label small" for="@radioId">@label</label>
                </div>
            }
        </div>
    </div>

    @* Month filter *@
    @if (Model.AvailableMonths.Count > 0)
    {
        <div>
            <label class="form-label small fw-semibold mb-1" for="month-filter-select">@Localizer["Label.Date"]</label>
            <select class="form-select form-select-sm" id="month-filter-select" name="month"
                    hx-get="?handler=Search"
                    hx-target="#media-content"
                    hx-swap="innerHTML"
                    hx-include="[name='q'],[name='type']"
                    hx-trigger="change">
                <option value="" selected="@(string.IsNullOrEmpty(Model.MonthFilter) ? "selected" : null)">
                    @Localizer["Label.AllDates"]
                </option>
                @foreach (MonthBucketVm bucket in Model.AvailableMonths)
                {
                    <option value="@bucket.Value"
                            selected="@(Model.MonthFilter == bucket.Value ? "selected" : null)">
                        @bucket.Label
                    </option>
                }
            </select>
        </div>
    }
</div>
