@page
@model Blogify.Web.Areas.BlogAdmin.Pages.Members.InviteModel
@{
    ViewData["Title"] = @Localizer["BlogAdmin.Members.InviteTitle"].Value;
}

<div class="mb-4">
    <a asp-page="/Members/Index" asp-area="BlogAdmin" asp-route-blogSlug="@ViewContext.RouteData.Values["blogSlug"]?.ToString()" class="text-muted small text-decoration-none">
        &larr; @Localizer["BlogAdmin.Members.BackToMembers"]
    </a>
</div>

<h4 class="fw-semibold mb-4">@Localizer["BlogAdmin.Members.InviteHeading"]</h4>

<div class="card border-0 shadow-sm" style="max-width:540px">
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">@Localizer["Label.Email"]</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="off" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Role" class="form-label">@Localizer["Label.Role"]</label>
                <select asp-for="Input.Role" class="form-select">
                    <option value="Writer">@Localizer["BlogAdmin.Members.Role.Writer"]</option>
                    <option value="Editor">@Localizer["BlogAdmin.Members.Role.Editor"]</option>
                    <option value="Admin">@Localizer["BlogAdmin.Members.Role.Admin"]</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger small"></span>
            </div>

            <div class="alert alert-info small">
                @Localizer["BlogAdmin.Members.InviteNote"]
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@Localizer["BlogAdmin.Members.InviteSend"]</button>
                <a asp-page="/Members/Index" asp-area="BlogAdmin" asp-route-blogSlug="@ViewContext.RouteData.Values["blogSlug"]?.ToString()" class="btn btn-outline-secondary">@Localizer["Action.Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
