@page
@model Blogify.Web.Areas.BlogAdmin.Pages.Posts.CreateModel
@{
    ViewData["Title"] = Localizer["Page.Title.BlogAdmin.NewPost"].Value;
}

<form method="post" id="createPostForm" novalidate>

    <div class="pe-header py-2">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <a asp-area="BlogAdmin" asp-page="/Posts/Index"
               class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                     viewBox="0 0 16 16" aria-hidden="true">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                </svg>
                @Localizer["Nav.Posts"]
            </a>
            <span class="badge bg-secondary">@Localizer["Post.Status.Draft"]</span>
            <span class="pe-save-status ms-1" id="peSaveStatus" aria-live="polite"></span>
            <div class="ms-auto d-none d-lg-flex gap-2">
                <button type="submit" name="Input.Publish" value="false"
                        class="btn btn-sm btn-outline-secondary">
                    @Localizer["Action.SaveDraft"]
                </button>
                <button type="submit" name="Input.Publish" value="true"
                        class="btn btn-sm btn-primary">
                    @Localizer["Action.Publish"]
                </button>
            </div>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-2" role="alert"></div>

    <div class="row g-4 pe-content-area">

        <div class="col-lg-8">

            <label for="postTitle" class="visually-hidden">@Localizer["Label.Title"]</label>
            <textarea id="postTitle" name="Input.Title" class="pe-title-input"
                      rows="1" placeholder="@Localizer["Page.Title.BlogAdmin.NewPost"].Value…"
                      autocomplete="off" maxlength="500">@Model.Input.Title</textarea>
            <span asp-validation-for="Input.Title" class="text-danger small d-block"></span>

            <div class="pe-slug-wrap my-2" id="slugDisplayWrap">
                <span class="pe-slug-display">/&nbsp;<span id="slugDisplay">@Model.Input.Slug</span></span>
                <button type="button" class="pe-slug-edit-btn" id="slugEditBtn"
                        aria-label="@Localizer["Action.EditUrl"].Value">&#9998;</button>
            </div>

            <div class="mb-3" id="slugEditWrap"
                 @(Model.ModelState["Input.Slug"]?.Errors.Count > 0 ? "" : "hidden")>
                <label asp-for="Input.Slug" class="form-label small fw-semibold">@Localizer["Label.Slug"]</label>
                <div class="input-group">
                    <span class="input-group-text text-muted">/</span>
                    <input asp-for="Input.Slug" class="form-control" id="postSlug"
                           placeholder="my-post-slug" autocomplete="off" />
                </div>
                <div class="d-flex align-items-center justify-content-between mt-1">
                    <div class="form-text">@Localizer["Label.Slug.Help.Create"]</div>
                    <button type="button" class="btn btn-link btn-sm p-0 text-muted" id="slugDoneBtn"
                            aria-label="@Localizer["Action.Cancel"].Value">&#10005;</button>
                </div>
                <span asp-validation-for="Input.Slug" class="text-danger small"></span>
            </div>

            <label id="postEditorLabel" class="visually-hidden">@Localizer["Label.Content"]</label>
            <div id="postEditorWrapper" class="post-editor-wrapper"
                 role="group" aria-labelledby="postEditorLabel"></div>
            <textarea asp-for="Input.Content" id="postEditorHidden"
                      class="visually-hidden" tabindex="-1" aria-hidden="true"></textarea>
            <span asp-validation-for="Input.Content" class="text-danger small"></span>

            <div class="pe-editor-footer">
                <span id="wordCountDisplay" aria-live="polite">0 words &middot; 0 min read</span>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="pe-settings-sidebar">

                <div class="pe-status-panel">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge bg-secondary">@Localizer["Post.Status.Draft"]</span>
                    </div>
                    <div class="text-muted">
                        @Localizer["Label.Author"]: @User.Identity?.Name
                    </div>
                </div>

                <div class="pe-settings-section">
                    <button type="button" class="pe-settings-toggle"
                            data-bs-toggle="collapse" data-bs-target="#featuredImageCollapse"
                            aria-expanded="true" aria-controls="featuredImageCollapse">
                        @Localizer["Label.FeaturedImage"]
                        <span class="pe-toggle-icon" aria-hidden="true">&#9660;</span>
                    </button>
                    <div id="featuredImageCollapse" class="collapse show pe-settings-body">
                        <partial name="_MediaPickerField"
                                 model="@(new MediaPickerFieldVm("coverImageId", "Input.CoverImageId", Model.Input.CoverImageId, null, "mediaPickerModal"))" />
                    </div>
                </div>

                <div class="pe-settings-section">
                    <button type="button" class="pe-settings-toggle"
                            data-bs-toggle="collapse" data-bs-target="#categoriesCollapse"
                            aria-expanded="true" aria-controls="categoriesCollapse">
                        @Localizer["Nav.Categories"]
                        <span class="badge bg-secondary ms-1" id="categoriesBadge"
                              aria-live="polite"
                              style="@(Model.AvailableCategories.Count(c => c.IsSelected) == 0 ? "display:none" : "")">
                            @Model.AvailableCategories.Count(c => c.IsSelected)
                        </span>
                        <span class="pe-toggle-icon" aria-hidden="true">&#9660;</span>
                    </button>
                    <div id="categoriesCollapse" class="collapse show pe-settings-body">
                        @if (Model.AvailableCategories.Count == 0)
                        {
                            <p class="text-muted small mb-0">
                                @Localizer["Label.Categories.None"]
                                <a asp-area="BlogAdmin" asp-page="/Categories/Create">@Localizer["Label.Categories.Create"]</a>.
                            </p>
                        }
                        else
                        {
                            <div aria-hidden="true" style="display:none" id="categoryCheckboxes">
                                @foreach (CategorySelectItem category in Model.AvailableCategories)
                                {
                                    <div>
                                        <input type="checkbox" name="SelectedCategoryIds"
                                               value="@category.Id" id="cat_@category.Id"
                                               @(category.IsSelected ? "checked" : "") />
                                        <label for="cat_@category.Id">@category.Name</label>
                                    </div>
                                }
                            </div>
                            <div class="pe-category-pills mb-2" id="categoryPills"
                                 aria-live="polite"
                                 aria-label="@Localizer["Nav.Categories"].Value"></div>
                            <div class="pe-category-search-wrap">
                                <input type="text" class="form-control form-control-sm"
                                       id="categorySearch" autocomplete="off"
                                       placeholder="@Localizer["Label.Categories.Search"].Value"
                                       aria-label="@Localizer["Label.Categories.Search"].Value" />
                                <div id="categoryDropdown" class="pe-category-dropdown" role="listbox"></div>
                            </div>
                        }
                    </div>
                </div>

                <div class="pe-settings-section">
                    <button type="button" class="pe-settings-toggle"
                            data-bs-toggle="collapse" data-bs-target="#excerptCollapse"
                            aria-expanded="true" aria-controls="excerptCollapse">
                        @Localizer["Label.Excerpt"]
                        <span class="pe-toggle-icon" aria-hidden="true">&#9660;</span>
                    </button>
                    <div id="excerptCollapse" class="collapse show pe-settings-body">
                        <label asp-for="Input.Excerpt" class="visually-hidden">@Localizer["Label.Excerpt"]</label>
                        <textarea asp-for="Input.Excerpt" class="form-control form-control-sm" rows="3"
                                  id="excerptInput"
                                  placeholder="@Localizer["Label.Excerpt.Placeholder"].Value"></textarea>
                        <div class="d-flex justify-content-between align-items-baseline mt-1">
                            <div class="form-text">@Localizer["Label.Excerpt.Help"]</div>
                            <span class="pe-char-count" id="excerptCount" aria-live="polite">0/500</span>
                        </div>
                        <span asp-validation-for="Input.Excerpt" class="text-danger small"></span>
                    </div>
                </div>

                <div class="pe-settings-section">
                    <button type="button" class="pe-settings-toggle"
                            data-bs-toggle="collapse" data-bs-target="#seoCollapse"
                            aria-expanded="true" aria-controls="seoCollapse">
                        @Localizer["Label.Seo"]
                        <span class="pe-toggle-icon" aria-hidden="true">&#9660;</span>
                    </button>
                    <div id="seoCollapse" class="collapse show pe-settings-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <label asp-for="Input.MetaTitle"
                                       class="form-label small fw-semibold mb-0">@Localizer["Label.MetaTitle"]</label>
                                <span class="pe-char-count" id="metaTitleCount" aria-live="polite">0/60</span>
                            </div>
                            <input asp-for="Input.MetaTitle" class="form-control form-control-sm"
                                   id="metaTitleInput"
                                   placeholder="@Localizer["Label.MetaTitle.Placeholder"].Value"
                                   autocomplete="off" />
                            <span asp-validation-for="Input.MetaTitle" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <label asp-for="Input.MetaDescription"
                                       class="form-label small fw-semibold mb-0">@Localizer["Label.MetaDescription"]</label>
                                <span class="pe-char-count" id="metaDescCount" aria-live="polite">0/160</span>
                            </div>
                            <textarea asp-for="Input.MetaDescription" class="form-control form-control-sm"
                                      id="metaDescInput" rows="3"
                                      placeholder="@Localizer["Label.MetaDescription.Placeholder"].Value"></textarea>
                            <span asp-validation-for="Input.MetaDescription" class="text-danger small"></span>
                        </div>
                        <div class="pe-serp-preview" aria-label="Search result preview">
                            <div class="pe-serp-url">yoursite.com/&thinsp;<span id="serpSlug">@Model.Input.Slug</span></div>
                            <div class="pe-serp-title" id="serpTitle">@Localizer["Label.Title"].Value&hellip;</div>
                            <div class="pe-serp-desc" id="serpDesc">@Localizer["Label.MetaDescription.Placeholder"].Value</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="pe-mobile-actions d-lg-none" aria-label="Post actions">
        <button type="submit" name="Input.Publish" value="false"
                class="btn btn-outline-secondary flex-fill">
            @Localizer["Action.SaveDraft"]
        </button>
        <button type="submit" name="Input.Publish" value="true"
                class="btn btn-primary flex-fill">
            @Localizer["Action.Publish"]
        </button>
    </div>

    <partial name="_EditorImagePickerModal" model='"editorImageInsert"' />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="~/css/post-editor.css" asp-append-version="true" />
    <script type="module">
        import { initPostEditor } from '/js/post-editor.js';
        await initPostEditor('postEditorWrapper', 'postEditorHidden', 'createPostForm');
    </script>
    <script>
    (function () {
        var titleInput      = document.getElementById('postTitle');
        var slugInput       = document.getElementById('postSlug');
        var slugDisplay     = document.getElementById('slugDisplay');
        var slugDisplayWrap = document.getElementById('slugDisplayWrap');
        var slugEditWrap    = document.getElementById('slugEditWrap');
        var slugEditBtn     = document.getElementById('slugEditBtn');
        var slugDoneBtn     = document.getElementById('slugDoneBtn');
        var editorHidden    = document.getElementById('postEditorHidden');
        var wordCountEl     = document.getElementById('wordCountDisplay');
        var excerptInput    = document.getElementById('excerptInput');
        var excerptCount    = document.getElementById('excerptCount');
        var metaTitleInput  = document.getElementById('metaTitleInput');
        var metaTitleCount  = document.getElementById('metaTitleCount');
        var metaDescInput   = document.getElementById('metaDescInput');
        var metaDescCount   = document.getElementById('metaDescCount');
        var serpSlug        = document.getElementById('serpSlug');
        var serpTitle       = document.getElementById('serpTitle');
        var serpDesc        = document.getElementById('serpDesc');
        var categoryCheckboxes = document.getElementById('categoryCheckboxes');
        var categoryPills   = document.getElementById('categoryPills');
        var categorySearch  = document.getElementById('categorySearch');
        var categoryDropdown= document.getElementById('categoryDropdown');
        var categoriesBadge = document.getElementById('categoriesBadge');
        var saveStatusEl    = document.getElementById('peSaveStatus');

        // Title auto-resize
        function resizeTitle() {
            if (!titleInput) return;
            titleInput.style.height = 'auto';
            titleInput.style.height = titleInput.scrollHeight + 'px';
        }
        if (titleInput) { resizeTitle(); titleInput.addEventListener('input', resizeTitle); }

        // Slug auto-generation
        var slugManuallyEdited = false;

        function generateSlug(text) {
            return text.toLowerCase().trim()
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        function updateSlugDisplay() {
            if (slugDisplay && slugInput) {
                slugDisplay.textContent = slugInput.value || '\u2026';
            }
            updateSerp();
        }

        if (slugInput) {
            slugInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') e.preventDefault(); });
            slugInput.addEventListener('input', function () {
                slugManuallyEdited = slugInput.value.length > 0;
                updateSlugDisplay();
            });
        }

        if (titleInput && slugInput) {
            titleInput.addEventListener('input', function () {
                if (!slugManuallyEdited) {
                    slugInput.value = generateSlug(titleInput.value);
                    updateSlugDisplay();
                }
                updateSerp();
            });
        }

        // Slug toggle
        if (slugEditBtn) {
            slugEditBtn.addEventListener('click', function () {
                if (slugDisplayWrap) slugDisplayWrap.hidden = true;
                if (slugEditWrap) slugEditWrap.hidden = false;
                if (slugInput) slugInput.focus();
            });
        }

        if (slugDoneBtn) {
            slugDoneBtn.addEventListener('click', function () {
                if (slugDisplayWrap) slugDisplayWrap.hidden = false;
                if (slugEditWrap) slugEditWrap.hidden = true;
                updateSlugDisplay();
            });
        }

        updateSlugDisplay();

        // Word count via intercepting hidden textarea value writes
        function extractTextFromBlockNote(jsonStr) {
            try {
                var blocks = JSON.parse(jsonStr);
                return Array.isArray(blocks) ? extractFromBlocks(blocks) : '';
            } catch (e) { return ''; }
        }

        function extractFromBlocks(blocks) {
            var text = '';
            for (var i = 0; i < blocks.length; i++) {
                var block = blocks[i];
                if (Array.isArray(block.content)) {
                    for (var j = 0; j < block.content.length; j++) {
                        var item = block.content[j];
                        if (item.type === 'text' && item.text) text += item.text + ' ';
                    }
                }
                if (Array.isArray(block.children) && block.children.length > 0) {
                    text += extractFromBlocks(block.children);
                }
            }
            return text;
        }

        function updateWordCount(jsonStr) {
            if (!wordCountEl) return;
            var text = extractTextFromBlockNote(jsonStr || '');
            var words = text.trim() ? text.trim().split(/\s+/).length : 0;
            var mins = Math.max(1, Math.ceil(words / 238));
            wordCountEl.textContent = words + ' words \u00B7 ' + mins + ' min read';
        }

        if (editorHidden) {
            var orig = Object.getOwnPropertyDescriptor(HTMLTextAreaElement.prototype, 'value');
            if (orig) {
                Object.defineProperty(editorHidden, 'value', {
                    get: function () { return orig.get.call(this); },
                    set: function (v) { orig.set.call(this, v); updateWordCount(v); }
                });
            }
            updateWordCount(editorHidden.value);
        }

        // Character counters
        function updateCharCount(input, countEl, max) {
            if (!input || !countEl) return;
            var len = input.value.length;
            countEl.textContent = len + '/' + max;
            countEl.classList.toggle('warn', len > max * 0.8 && len < max);
            countEl.classList.toggle('over', len >= max);
        }

        if (excerptInput) {
            excerptInput.addEventListener('input', function () { updateCharCount(excerptInput, excerptCount, 500); });
            updateCharCount(excerptInput, excerptCount, 500);
        }
        if (metaTitleInput) {
            metaTitleInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') e.preventDefault(); });
            metaTitleInput.addEventListener('input', function () { updateCharCount(metaTitleInput, metaTitleCount, 60); updateSerp(); });
            updateCharCount(metaTitleInput, metaTitleCount, 60);
        }
        if (metaDescInput) {
            metaDescInput.addEventListener('input', function () { updateCharCount(metaDescInput, metaDescCount, 160); updateSerp(); });
            updateCharCount(metaDescInput, metaDescCount, 160);
        }

        // SERP preview
        function updateSerp() {
            if (!serpSlug || !serpTitle || !serpDesc) return;
            serpSlug.textContent = (slugInput && slugInput.value) || '\u2026';
            serpTitle.textContent = (metaTitleInput && metaTitleInput.value)
                || (titleInput && titleInput.value) || 'Your post title';
            serpDesc.textContent = (metaDescInput && metaDescInput.value)
                || 'Your meta description will appear here\u2026';
        }
        updateSerp();

        // Category pill picker
        if (categoryCheckboxes && categoryPills && categorySearch && categoryDropdown) {
            function getCategories() {
                return Array.from(
                    categoryCheckboxes.querySelectorAll('input[type="checkbox"]')
                ).map(function (cb) {
                    var lbl = categoryCheckboxes.querySelector('label[for="' + cb.id + '"]');
                    return { id: cb.id, value: cb.value, name: lbl ? lbl.textContent.trim() : cb.value, el: cb };
                });
            }

            function renderPills() {
                categoryPills.innerHTML = '';
                getCategories().filter(function (c) { return c.el.checked; }).forEach(function (cat) {
                    var pill = document.createElement('span');
                    pill.className = 'pe-category-pill';
                    var removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'pe-category-pill-remove';
                    removeBtn.setAttribute('aria-label', 'Remove ' + cat.name);
                    removeBtn.textContent = '\u00D7';
                    removeBtn.addEventListener('click', function () {
                        cat.el.checked = false;
                        renderPills();
                        renderDropdown('');
                        updateBadge();
                    });
                    pill.appendChild(document.createTextNode(cat.name + ' '));
                    pill.appendChild(removeBtn);
                    categoryPills.appendChild(pill);
                });
                updateBadge();
            }

            function renderDropdown(query) {
                var filtered = getCategories().filter(function (c) {
                    return !c.el.checked && c.name.toLowerCase().includes(query.toLowerCase());
                });
                categoryDropdown.innerHTML = '';
                if (!filtered.length) { categoryDropdown.classList.remove('show'); return; }
                filtered.forEach(function (cat) {
                    var opt = document.createElement('div');
                    opt.className = 'pe-category-option';
                    opt.setAttribute('role', 'option');
                    opt.textContent = cat.name;
                    opt.addEventListener('click', function () {
                        cat.el.checked = true;
                        categorySearch.value = '';
                        categoryDropdown.classList.remove('show');
                        renderPills();
                        renderDropdown('');
                    });
                    categoryDropdown.appendChild(opt);
                });
                categoryDropdown.classList.add('show');
            }

            function updateBadge() {
                if (!categoriesBadge) return;
                var count = getCategories().filter(function (c) { return c.el.checked; }).length;
                categoriesBadge.textContent = count;
                categoriesBadge.style.display = count === 0 ? 'none' : '';
            }

            categorySearch.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var first = categoryDropdown.querySelector('.pe-category-option');
                    if (first) first.click();
                }
            });
            categorySearch.addEventListener('input', function () { renderDropdown(categorySearch.value); });
            categorySearch.addEventListener('focus', function () { renderDropdown(categorySearch.value); });
            document.addEventListener('click', function (e) {
                if (!e.target.closest('.pe-category-search-wrap')) {
                    categoryDropdown.classList.remove('show');
                }
            });
            renderPills();
        }

        // localStorage draft recovery
        var DRAFT_KEY = 'pe_draft_create';
        var draftTimer = null;

        function saveDraftLocally() {
            if (!titleInput) return;
            try {
                localStorage.setItem(DRAFT_KEY, JSON.stringify({
                    title: titleInput.value,
                    slug: slugInput ? slugInput.value : '',
                    savedAt: Date.now()
                }));
            } catch (e) { /* quota or private mode */ }
        }

        function checkLocalDraft() {
            try {
                var raw = localStorage.getItem(DRAFT_KEY);
                if (!raw) return;
                var draft = JSON.parse(raw);
                if (!draft.title || !draft.savedAt) return;
                if ((Date.now() - draft.savedAt) / 60000 > 1440) { localStorage.removeItem(DRAFT_KEY); return; }
                if (titleInput && titleInput.value.length === 0) {
                    var banner = document.createElement('div');
                    banner.className = 'alert alert-warning alert-dismissible d-flex align-items-center gap-2 mt-2';
                    banner.setAttribute('role', 'alert');
                    var restoreBtn = document.createElement('button');
                    restoreBtn.type = 'button';
                    restoreBtn.className = 'btn btn-sm btn-warning ms-auto';
                    restoreBtn.textContent = 'Restore draft';
                    restoreBtn.addEventListener('click', function () {
                        titleInput.value = draft.title;
                        if (slugInput) { slugInput.value = draft.slug; slugManuallyEdited = true; }
                        resizeTitle(); updateSlugDisplay(); updateSerp();
                        banner.remove();
                        localStorage.removeItem(DRAFT_KEY);
                    });
                    var closeBtn = document.createElement('button');
                    closeBtn.type = 'button';
                    closeBtn.className = 'btn-close';
                    closeBtn.setAttribute('data-bs-dismiss', 'alert');
                    closeBtn.setAttribute('aria-label', 'Close');
                    var msgSpan = document.createElement('span');
                    msgSpan.textContent = 'Unsaved draft: \u201C' + draft.title.substring(0, 60) + '\u201D';
                    banner.appendChild(msgSpan);
                    banner.appendChild(restoreBtn);
                    banner.appendChild(closeBtn);
                    document.getElementById('createPostForm').prepend(banner);
                }
            } catch (e) { /* ignore */ }
        }

        if (titleInput) {
            titleInput.addEventListener('input', function () {
                clearTimeout(draftTimer);
                draftTimer = setTimeout(saveDraftLocally, 2000);
                setSaveStatus('unsaved');
            });
        }

        var theForm = document.getElementById('createPostForm');
        if (theForm) {
            theForm.addEventListener('submit', function () { localStorage.removeItem(DRAFT_KEY); });
        }
        checkLocalDraft();

        // Save status indicator
        function setSaveStatus(state) {
            if (!saveStatusEl) return;
            saveStatusEl.className = 'pe-save-status ms-1';
            if (state === 'unsaved') {
                saveStatusEl.classList.add('pe-unsaved');
                saveStatusEl.textContent = '\u25CF Unsaved changes';
            } else {
                saveStatusEl.textContent = '';
            }
        }
    })();
    </script>
}
