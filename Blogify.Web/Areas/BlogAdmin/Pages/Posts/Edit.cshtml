@page "{id:guid}"
@model Blogify.Web.Areas.BlogAdmin.Pages.Posts.EditModel
@{
    ViewData["Title"] = $"Edit — {Model.PostTitle}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item">
                    <a asp-area="BlogAdmin" asp-page="/Posts/Index">Posts</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">Edit Post</h1>
    </div>
</div>

<form method="post" id="editPostForm" novalidate>
    @if (!Model.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
    }
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Content</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                        <input asp-for="Input.Title" class="form-control form-control-lg"
                               placeholder="Enter post title…" autocomplete="off"
                               id="postTitle" />
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Slug" class="form-label fw-semibold">Slug <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text text-muted">/</span>
                            <input asp-for="Input.Slug" class="form-control"
                                   placeholder="my-post-slug" autocomplete="off"
                                   id="postSlug" />
                        </div>
                        <div class="form-text">Lowercase letters, digits, and hyphens only.</div>
                        <span asp-validation-for="Input.Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Excerpt" class="form-label fw-semibold">Excerpt</label>
                        <textarea asp-for="Input.Excerpt" class="form-control" rows="3"
                                  placeholder="A short summary of the post (optional)…"></textarea>
                        <div class="form-text">Max 500 characters. Displayed in post listings.</div>
                        <span asp-validation-for="Input.Excerpt" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label for="postEditorHidden" class="form-label fw-semibold">Content <span class="text-danger">*</span></label>
                        <div id="postEditorWrapper" class="post-editor-wrapper"></div>
                        <textarea asp-for="Input.Content" id="postEditorHidden"
                                  class="visually-hidden" tabindex="-1"></textarea>
                        <span asp-validation-for="Input.Content" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Publish</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="Input.IsPublished" id="statusDraft"
                                   value="false" @(Model.Input.IsPublished ? "" : "checked") />
                            <label class="form-check-label" for="statusDraft">
                                <span class="badge bg-secondary me-1">Draft</span>
                                Save as draft
                            </label>
                        </div>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="radio"
                                   name="Input.IsPublished" id="statusPublished"
                                   value="true" @(Model.Input.IsPublished ? "checked" : "") />
                            <label class="form-check-label" for="statusPublished">
                                <span class="badge bg-success me-1">Published</span>
                                Published
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            Update Post
                        </button>
                        <a asp-area="BlogAdmin" asp-page="/Posts/Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Categories</div>
                <div class="card-body">
                    @if (Model.AvailableCategories.Count == 0)
                    {
                        <p class="text-muted small mb-0">
                            No categories yet.
                            <a asp-area="BlogAdmin" asp-page="/Categories/Create">Create one</a>.
                        </p>
                    }
                    else
                    {
                        <div class="overflow-auto" style="max-height: 200px;">
                            @foreach (var category in Model.AvailableCategories)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedCategoryIds" value="@category.Id"
                                           id="cat_@category.Id"
                                           @(category.IsSelected ? "checked" : "") />
                                    <label class="form-check-label" for="cat_@category.Id">
                                        @category.Name
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header fw-semibold">Featured Image</div>
                <div class="card-body">
                    <partial name="_MediaPickerField"
                             model="@(new MediaPickerFieldVm("coverImageId", "Input.CoverImageId", Model.Input.CoverImageId, Model.CoverImagePreviewUrl, "mediaPickerModal"))" />
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="~/css/post-editor.css" asp-append-version="true" />
    <script type="module">
        import { initPostEditor } from '/js/post-editor.js';
        await initPostEditor('postEditorWrapper', 'postEditorHidden', 'editPostForm');
    </script>
    <script>
        (function () {
            const titleInput = document.getElementById('postTitle');
            const slugInput  = document.getElementById('postSlug');

            if (!titleInput || !slugInput) return;

            titleInput.addEventListener('input', function () {
                slugInput.value = titleInput.value
                    .toLowerCase()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .trim()
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
            });
        })();
    </script>
}

