@page
@model Blogify.Web.Areas.BlogAdmin.Pages.Categories.EditModel
@{
    ViewData["Title"] = Localizer["Page.Title.BlogAdmin.EditCategory"].Value;
    string? blogSlug = ViewContext.RouteData.Values["blogSlug"]?.ToString();
}

<header class="b-page-header">
    <div>
        <p class="b-page-context">@Localizer["Nav.Categories"]</p>
        <h1>@Localizer["Page.Title.BlogAdmin.EditCategory"]</h1>
        <p>@Localizer["Categories.Form.EditDescription"]</p>
    </div>
    <a asp-area="BlogAdmin" asp-page="/Categories/Index" asp-route-blogSlug="@blogSlug" class="btn btn-outline-secondary">
        @Localizer["Categories.Back"]
    </a>
</header>

<form method="post" class="b-form-layout" novalidate>
    @if (!Model.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
    }

    <section class="b-form-section">
        <div>
            <h2>@Localizer["Categories.Form.DetailsTitle"]</h2>
            <p>@Localizer["Categories.Form.DetailsDescription"]</p>
        </div>
        <div class="b-form-section-fields">
            <div>
                <label asp-for="Input.Name" class="form-label fw-semibold">@Localizer["Label.Name"] <span class="text-danger">*</span></label>
                <input asp-for="Input.Name" class="form-control"
                       placeholder="@Localizer["Categories.Form.NamePlaceholder"].Value" autocomplete="off" />
                <div class="form-text">@Localizer["Categories.Form.NameHelp"]</div>
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Input.Slug" class="form-label fw-semibold">@Localizer["Label.Slug"] <span class="text-danger">*</span></label>
                <input asp-for="Input.Slug" class="form-control font-monospace"
                       placeholder="@Localizer["Categories.Form.SlugPlaceholder"].Value" autocomplete="off" />
                <div class="form-text">@Localizer["Categories.Form.SlugHelpEdit"]</div>
                <span asp-validation-for="Input.Slug" class="text-danger small"></span>
            </div>
        </div>
    </section>

    <section class="b-form-section">
        <div>
            <h2>@Localizer["Categories.Form.SearchSharingTitle"]</h2>
            <p>@Localizer["Categories.Form.SearchSharingDescription"]</p>
        </div>
        <div class="b-form-section-fields">
            <div>
                <div class="b-form-label-row">
                    <label asp-for="Input.MetaTitle" class="form-label fw-semibold">@Localizer["Label.MetaTitle"]</label>
                    <span class="b-character-count" id="metaTitleCount" aria-live="polite">0/60</span>
                </div>
                <input asp-for="Input.MetaTitle" class="form-control" id="metaTitleInput"
                       placeholder="@Localizer["Label.MetaTitle.Placeholder"].Value" autocomplete="off" />
                <div class="form-text">@Localizer["Label.MetaTitle.Help.Category"]</div>
                <span asp-validation-for="Input.MetaTitle" class="text-danger small"></span>
            </div>

            <div>
                <div class="b-form-label-row">
                    <label asp-for="Input.MetaDescription" class="form-label fw-semibold">@Localizer["Label.MetaDescription"]</label>
                    <span class="b-character-count" id="metaDescriptionCount" aria-live="polite">0/160</span>
                </div>
                <textarea asp-for="Input.MetaDescription" class="form-control" id="metaDescriptionInput" rows="4"
                          placeholder="@Localizer["Label.MetaDescription.Placeholder"].Value"></textarea>
                <div class="form-text">@Localizer["Label.MetaDescription.Help.Category"]</div>
                <span asp-validation-for="Input.MetaDescription" class="text-danger small"></span>
            </div>
        </div>
    </section>

    <div class="b-form-actions">
        <a asp-area="BlogAdmin" asp-page="/Categories/Index" asp-route-blogSlug="@blogSlug" class="btn btn-outline-secondary">@Localizer["Action.Cancel"]</a>
        <button type="submit" class="btn btn-primary">@Localizer["Action.Save"]</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function bindCharacterCount(inputId, countId, maxLength) {
                const input = document.getElementById(inputId);
                const count = document.getElementById(countId);
                const update = function () {
                    count.textContent = `${input.value.length}/${maxLength}`;
                };
                input.addEventListener('input', update);
                update();
            }

            bindCharacterCount('metaTitleInput', 'metaTitleCount', 60);
            bindCharacterCount('metaDescriptionInput', 'metaDescriptionCount', 160);
        })();
    </script>
}
