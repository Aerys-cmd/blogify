@page "{id:guid}"
@model Blogify.Web.Areas.BlogAdmin.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = $"Delete — {Model.CategoryName}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item">
                <a asp-area="BlogAdmin" asp-page="/Categories/Index">Categories</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>
    <h1 class="h3 mb-0">Delete Category</h1>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white fw-semibold">Confirm Deletion</div>
            <div class="card-body">
                <p>Are you sure you want to delete the following category? This action cannot be undone.</p>
                <dl class="row mb-4">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.CategoryName</dd>
                    <dt class="col-sm-3">Slug</dt>
                    <dd class="col-sm-9 font-monospace text-muted">@Model.CategorySlug</dd>
                </dl>
                <form method="post">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-area="BlogAdmin" asp-page="/Categories/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

