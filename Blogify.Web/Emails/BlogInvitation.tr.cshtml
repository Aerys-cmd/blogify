@model Blogify.Web.Services.Email.BlogInvitationEmailViewModel
@{
    Layout = "/Emails/_Layout.cshtml";
    ViewData["Language"] = "tr";
    ViewData["Title"] = "Blog daveti";
}
<h1 style="font-size:24px;margin:0 0 16px">Blog daveti aldınız</h1>
<p style="line-height:1.6"><strong>@Model.BlogTitle</strong> bloguna <strong>@Model.Role</strong> rolüyle katılmaya davet edildiniz.</p>
<p style="margin:24px 0">
    <a href="@Model.InvitationUrl" style="background:#18181b;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block">Daveti kabul et</a>
</p>
<p style="line-height:1.6;color:#52525b">Bu davetin süresi 7 gün sonra dolar.</p>
