@model Blogify.Web.Services.Email.PasswordResetEmailViewModel
@{
    Layout = "/Emails/_Layout.cshtml";
    ViewData["Language"] = "en";
    ViewData["Title"] = "Reset your password";
}
<h1 style="font-size:24px;margin:0 0 16px">Reset your password</h1>
<p style="line-height:1.6">We received a request to reset your Blogify password.</p>
<p style="margin:24px 0">
    <a href="@Model.ResetUrl" style="background:#18181b;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block">Reset password</a>
</p>
<p style="line-height:1.6;color:#52525b">If you did not request this, you can safely ignore this email.</p>
