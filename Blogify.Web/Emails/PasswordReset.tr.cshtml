@model Blogify.Web.Services.Email.PasswordResetEmailViewModel
@{
    Layout = "/Emails/_Layout.cshtml";
    ViewData["Language"] = "tr";
    ViewData["Title"] = "Şifrenizi sıfırlayın";
}
<h1 style="font-size:24px;margin:0 0 16px">Şifrenizi sıfırlayın</h1>
<p style="line-height:1.6">Blogify şifrenizi sıfırlamak için bir istek aldık.</p>
<p style="margin:24px 0">
    <a href="@Model.ResetUrl" style="background:#18181b;color:#ffffff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block">Şifreyi sıfırla</a>
</p>
<p style="line-height:1.6;color:#52525b">Bu isteği siz yapmadıysanız bu e-postayı güvenle yok sayabilirsiniz.</p>
