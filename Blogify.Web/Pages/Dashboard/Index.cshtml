@page
@model Blogify.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = @Localizer["Dashboard.Title"].Value;
    Layout = "/Pages/Shared/_LandingLayout.cshtml";
}

<div class="container b-dashboard-page">
    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    <header class="b-page-header"><div><p class="b-page-context">@Localizer["Dashboard.Context"]</p><h1>@Localizer["Dashboard.MyBlogs"]</h1><p>@Localizer["Dashboard.Description"]</p></div><a asp-page="/Dashboard/CreateBlog" class="btn btn-primary">@Localizer["Action.CreateBlog"]</a></header>

    @if (Model.OwnedBlogs.Count > 0)
    {
        <h2 class="h5 mb-3">@Localizer["Dashboard.Owned"]</h2>
        <div class="b-site-list mb-5">
            @foreach (Blogify.Web.Services.AccessibleBlog blog in Model.OwnedBlogs)
            {
                <article class="b-site-row">
                    <img src="/blogify-mark.svg" alt="" width="44" height="44" />
                    <div><h3>@blog.Title</h3><p>@(blog.Subdomain).blogify.com</p></div>
                    <span class="b-status b-status-live">@Localizer["Dashboard.OwnerRole"]</span>
                    <div class="b-site-actions">
                                <a href="/app/admin/@blog.Subdomain" class="btn btn-dark">
                                    @Localizer["Dashboard.ManageBlog"]
                                </a>
                                <a href="@blog.PublicUrl" target="_blank" rel="noopener" class="btn btn-outline-secondary">
                                    @Localizer["Dashboard.ViewBlog"]
                                </a>
                    </div>
                </article>
            }
        </div>
    }

    @if (Model.MemberBlogs.Count > 0)
    {
        <h2 class="h5 mb-3">@Localizer["Dashboard.MemberOf"]</h2>
        <div class="b-site-list mb-5">
            @foreach (Blogify.Web.Services.AccessibleBlog blog in Model.MemberBlogs)
            {
                <article class="b-site-row">
                    <img src="/blogify-mark.svg" alt="" width="44" height="44" />
                    <div><h3>@blog.Title</h3><p>@(blog.Subdomain).blogify.com</p></div>
                    <span class="b-status">@blog.Role</span>
                    <div class="b-site-actions">
                                <a href="/app/admin/@blog.Subdomain" class="btn btn-dark">
                                    @Localizer["Dashboard.ManageBlog"]
                                </a>
                                <a href="@blog.PublicUrl" target="_blank" rel="noopener" class="btn btn-outline-secondary">
                                    @Localizer["Dashboard.ViewBlog"]
                                </a>
                                <form method="post" asp-page-handler="Leave">
                                    <input type="hidden" name="blogId" value="@blog.Id" />
                                    <button type="submit" class="btn btn-outline-danger" data-confirm-message="@Localizer["Dashboard.LeaveConfirm", blog.Title].Value">@Localizer["Dashboard.Leave"]</button>
                                </form>
                    </div>
                </article>
            }
        </div>
    }

    @if (Model.OwnedBlogs.Count == 0 && Model.MemberBlogs.Count == 0)
    {
        <div class="text-center py-5">
            <p class="text-muted mb-3">@Localizer["Dashboard.NoBlogs"]</p>
            <a asp-page="/Dashboard/CreateBlog" class="btn btn-primary">
                @Localizer["Action.CreateBlog"]
            </a>
        </div>
    }

</div>
