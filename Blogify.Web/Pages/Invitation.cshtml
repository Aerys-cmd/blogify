@page
@model Blogify.Web.Pages.InvitationModel
@{
    ViewData["Title"] = Localizer["Invitation.Title"].Value;
}

<div class="container py-5" style="max-width:640px">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h1 class="h4 mb-3">@Localizer["Invitation.Title"]</h1>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            else
            {
                <p>@Localizer["Invitation.Invited", Model.BlogTitle, Model.Role]</p>
                <div class="d-flex gap-2">
                    <form method="post" asp-page-handler="Accept">
                        <input type="hidden" name="token" value="@Model.Token" />
                        <button type="submit" class="btn btn-primary">@Localizer["Invitation.Accept"]</button>
                    </form>
                    <form method="post" asp-page-handler="Decline">
                        <input type="hidden" name="token" value="@Model.Token" />
                        <button type="submit" class="btn btn-outline-danger">@Localizer["Invitation.Decline"]</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
