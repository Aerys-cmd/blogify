@page
@model Blogify.Web.Pages.GetStarted.CompleteModel
@{
    Layout = "_LandingLayout";
}

<section class="py-5">
    <div class="container text-center" style="max-width: 600px;">
        <div class="mb-4">
            <span class="display-1 text-success">✓</span>
        </div>
        <h1 class="fw-bold mb-3">Your blog is live!</h1>
        <p class="lead text-muted mb-4">
            <strong>@Model.BlogTitle</strong> is all set and ready for your first post.
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mb-4">
            <a class="btn btn-primary btn-lg"
               href="http://@(Model.BlogSubdomain).localhost/admin">
                Open Blog Admin
            </a>
            <a class="btn btn-outline-secondary btn-lg"
               href="http://@(Model.BlogSubdomain).localhost">
                View Your Blog
            </a>
        </div>

        <div class="alert alert-info text-start" role="note">
            <strong>Note:</strong> Your blog is available at
            <code>@(Model.BlogSubdomain).localhost</code> locally.
            In production, it will be accessible at
            <code>@(Model.BlogSubdomain).yourdomain.com</code>.
        </div>
    </div>
</section>
