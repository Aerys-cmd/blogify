@page
@model Blogify.Web.Pages.GetStarted.CompleteModel
@{
    Layout = "_LandingLayout";
}

<section class="py-5">
    <div class="container text-center" style="max-width: 600px;">
        <div class="mb-4">
            <span class="display-1 text-success">✓</span>
        </div>
        <h1 class="fw-bold mb-3">@Localizer["GetStarted.Complete.Heading"]</h1>
        <p class="lead text-muted mb-4">
            <strong>@Model.BlogTitle</strong> @Localizer["GetStarted.Complete.ReadyMessage"]
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mb-4">
            <a class="btn btn-primary btn-lg"
               href="@Model.AdminUrl">
                @Localizer["GetStarted.Complete.OpenAdmin"]
            </a>
            <a class="btn btn-outline-secondary btn-lg"
               href="@Model.BlogUrl">
                @Localizer["GetStarted.Complete.ViewBlog"]
            </a>
        </div>

        <div class="alert alert-info text-start" role="note">
            <strong>@Localizer["GetStarted.Complete.Note"]</strong> @Localizer["GetStarted.Complete.LocalNote"]
            <code>@(Model.BlogSubdomain).blogify.com.tr</code> @Localizer["GetStarted.Complete.LocalNoteSuffix"]
            <code>@(Model.BlogSubdomain).yourdomain.com</code>.
        </div>
    </div>
</section>
