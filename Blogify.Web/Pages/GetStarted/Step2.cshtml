@page
@model Blogify.Web.Pages.GetStarted.Step2Model
@{
    Layout = "_LandingLayout";
}

<section class="py-5">
    <div class="container" style="max-width: 480px;">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <span class="badge bg-primary mb-2">Step 2 of 2</span>
                    <h2 class="fw-bold">Set up your blog</h2>
                    <p class="text-muted">Give your blog a name and a home on the web.</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label">Blog title</label>
                        <input asp-for="Input.Title" class="form-control" placeholder="My Awesome Blog" />
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Subdomain" class="form-label">Subdomain</label>
                        <input asp-for="Input.Subdomain" id="subdomainInput" class="form-control"
                               placeholder="myblog" autocomplete="off" />
                        <span asp-validation-for="Input.Subdomain" class="text-danger small"></span>
                        <div class="form-text mt-1">
                            Your blog will be at: <strong><span id="subdomainPreview">myblog</span>.localhost</strong>
                        </div>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Launch My Blog &rarr;</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var input = document.getElementById('subdomainInput');
            var preview = document.getElementById('subdomainPreview');
            if (input && preview) {
                input.addEventListener('input', function () {
                    var val = input.value.trim().toLowerCase();
                    preview.textContent = val.length > 0 ? val : 'myblog';
                });
            }
        }());
    </script>
}
