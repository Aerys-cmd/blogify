@page "/Index"
@model IndexModel
@{
    Layout = "_LandingLayout";
}

<section class="b-hero">
    <div class="container b-hero-grid">
        <div>
            <p class="b-hero-note">@Localizer["Landing.Hero.Note"]</p>
            <h1>@Localizer["Landing.Hero.Heading"]</h1>
            <p class="b-hero-copy">@Localizer["Landing.Hero.Copy"]</p>
            <div class="d-flex flex-column flex-sm-row gap-3 mt-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-dark btn-lg" asp-page="/Dashboard/CreateBlog">@Localizer["Action.CreateBlog"]</a>
                }
                else
                {
                    <a class="btn btn-dark btn-lg" asp-area="Identity" asp-page="/Account/Register">@Localizer["Landing.Action.CreateFreeBlog"]</a>
                }
                <a class="btn btn-outline-dark btn-lg" href="#examples">@Localizer["Landing.Action.SeePublishedBlog"]</a>
            </div>
        </div>
        <div class="b-product-composition" aria-label="@Localizer["Landing.Aria.EditorPreview"].Value">
            <div class="b-composition-toolbar"><span></span><span>@Localizer["Message.PostSaved"]</span><strong>@Localizer["Action.Publish"]</strong></div>
            <div class="b-composition-body">
                <small>@Localizer["Landing.Preview.Label"]</small>
                <h2>@Localizer["Landing.Preview.Title"]</h2>
                <p>@Localizer["Landing.Preview.Copy"]</p>
                <div class="b-composition-lines"><i></i><i></i><i></i></div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="b-narrative">
    <div class="container">
        <div class="b-narrative-row"><span>@Localizer["Landing.Feature.Write.Label"]</span><div><h2>@Localizer["Landing.Feature.Write.Title"]</h2><p>@Localizer["Landing.Feature.Write.Copy"]</p></div></div>
        <div class="b-narrative-row"><span>@Localizer["Landing.Feature.Publish.Label"]</span><div><h2>@Localizer["Landing.Feature.Publish.Title"]</h2><p>@Localizer["Landing.Feature.Publish.Copy"]</p></div></div>
        <div class="b-narrative-row"><span>@Localizer["Landing.Feature.Understand.Label"]</span><div><h2>@Localizer["Landing.Feature.Understand.Title"]</h2><p>@Localizer["Landing.Feature.Understand.Copy"]</p></div></div>
    </div>
</section>

<section id="examples" class="b-examples">
    <div class="container">
        <div class="b-section-heading"><h2>@Localizer["Landing.Examples.Title"]</h2><p>@Localizer["Landing.Examples.Copy"]</p></div>
        <div class="b-theme-gallery">
            <figure><img src="/images/theme-previews/default.png" alt="@Localizer["Landing.Examples.DefaultAlt"].Value" /><figcaption>Default</figcaption></figure>
            <figure><img src="/images/theme-previews/minimal.png" alt="@Localizer["Landing.Examples.MinimalAlt"].Value" /><figcaption>Minimal</figcaption></figure>
            <figure><img src="/images/theme-previews/aurora.png" alt="@Localizer["Landing.Examples.AuroraAlt"].Value" /><figcaption>Aurora</figcaption></figure>
        </div>
    </div>
</section>

<section id="how-it-works" class="b-process">
    <div class="container">
        <h2>@Localizer["Landing.Process.Title"]</h2>
        <div class="b-process-list">
            <div><strong>01</strong><h3>@Localizer["Index.HowItWorks.Step1.Title"]</h3><p>@Localizer["Index.HowItWorks.Step1.Description"]</p></div>
            <div><strong>02</strong><h3>@Localizer["Index.HowItWorks.Step2.Title"]</h3><p>@Localizer["Index.HowItWorks.Step2.Description"]</p></div>
            <div><strong>03</strong><h3>@Localizer["Index.HowItWorks.Step3.Title"]</h3><p>@Localizer["Index.HowItWorks.Step3.Description"]</p></div>
        </div>
    </div>
</section>

<section class="b-final-cta">
    <div class="container">
        <h2>@Localizer["Landing.Final.Title"]</h2>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-dark btn-lg" asp-page="/Dashboard/CreateBlog">@Localizer["Action.CreateBlog"]</a>
        }
        else
        {
            <a class="btn btn-dark btn-lg" asp-area="Identity" asp-page="/Account/Register">@Localizer["Landing.Final.Action"]</a>
        }
    </div>
</section>
