@page "/Index"
@model IndexModel
@{
    Layout = "_LandingLayout";
}

<!-- Hero Section -->
<section class="d-flex align-items-center justify-content-center text-center text-white bg-dark"
         style="min-height: 100vh; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3">@Localizer["Index.Hero.Heading"]</h1>
        <p class="lead mb-4" style="max-width: 600px; margin: 0 auto;">
            @Localizer["Index.Hero.Subheading"]
        </p>
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-4">
            <a class="btn btn-primary btn-lg px-5" asp-page="/GetStarted/Step1">@Localizer["Index.Hero.PrimaryButton"]</a>
            <a class="btn btn-outline-light btn-lg px-5" href="#features">@Localizer["Index.Hero.SecondaryButton"]</a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">@Localizer["Index.Features.Heading"]</h2>
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">🌐</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Subdomain.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Subdomain.Description"]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">🎨</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Themes.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Themes.Description"]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">🗂️</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Categories.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Categories.Description"]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">✍️</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Editor.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Editor.Description"]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">🖼️</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Media.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Media.Description"]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="card-body">
                        <div class="fs-1 mb-3" aria-hidden="true">📝</div>
                        <h5 class="card-title fw-semibold">@Localizer["Index.Features.Markdown.Title"]</h5>
                        <p class="card-text text-muted">@Localizer["Index.Features.Markdown.Description"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">@Localizer["Index.HowItWorks.Heading"]</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-12 col-md-4 text-center">
                <div class="display-4 fw-bold text-primary mb-3">①</div>
                <h5 class="fw-semibold">@Localizer["Index.HowItWorks.Step1.Title"]</h5>
                <p class="text-muted">@Localizer["Index.HowItWorks.Step1.Description"]</p>
            </div>
            <div class="col-12 col-md-4 text-center">
                <div class="display-4 fw-bold text-primary mb-3">②</div>
                <h5 class="fw-semibold">@Localizer["Index.HowItWorks.Step2.Title"]</h5>
                <p class="text-muted">@Localizer["Index.HowItWorks.Step2.Description"]</p>
            </div>
            <div class="col-12 col-md-4 text-center">
                <div class="display-4 fw-bold text-primary mb-3">③</div>
                <h5 class="fw-semibold">@Localizer["Index.HowItWorks.Step3.Title"]</h5>
                <p class="text-muted">@Localizer["Index.HowItWorks.Step3.Description"]</p>
            </div>
        </div>
    </div>
</section>

<!-- Social Proof Stats Bar -->
<section class="py-4 bg-primary text-white text-center">
    <div class="container">
        @if (Model.TotalBlogCount > 0)
        {
            <p class="fs-4 mb-0 fw-semibold">
                @Localizer["Index.Stats.JoinPrefix"] <strong>@Model.TotalBlogCount</strong> @Localizer[Model.TotalBlogCount == 1 ? "Index.Stats.BlogSingular" : "Index.Stats.BlogPlural"]
            </p>
        }
        else
        {
            <p class="fs-4 mb-0 fw-semibold">@Localizer["Index.Stats.BeFirst"]</p>
        }
    </div>
</section>

<!-- Final CTA Section -->
<section class="py-5 text-center">
    <div class="container" style="max-width: 640px;">
        <h2 class="fw-bold mb-3">@Localizer["Index.CTA.Heading"]</h2>
        <p class="text-muted mb-4">@Localizer["Index.CTA.Description"]</p>
        <a class="btn btn-primary btn-lg px-5" asp-page="/GetStarted/Step1">@Localizer["Index.CTA.Button"]</a>
    </div>
</section>
